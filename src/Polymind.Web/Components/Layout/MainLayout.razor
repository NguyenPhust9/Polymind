@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IBrowserViewportService Viewport
@inject AgentScope AgentScope
@implements IDisposable

<MudThemeProvider @ref="_themeProvider" Theme="Polymind.Web.Theme.PolymindTheme.Default" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
@* Mặc định dialog: full-width + có nút đóng (X) cho dễ thao tác trên điện thoại *@
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Medium" CloseButton="true" CloseOnEscapeKey="true" />
<MudSnackbarProvider />

<MudLayout Class="@($"theme-shell {(_isDarkMode ? "theme-dark" : "theme-light")}")">
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <span class="appbar-logo ml-1"><img src="img/logo-polymind.png?v=20260629-logo2" alt="POLYMIND" /></span>
        <MudText Typo="Typo.h6" Class="ml-2 d-none d-sm-flex" Style="font-weight:800;letter-spacing:.02em">POLYMIND OLMS</MudText>
        <MudText Typo="Typo.caption" Class="ml-2 d-none d-lg-flex" Style="opacity:.85">Quản lý Xuất khẩu Lao động</MudText>
        <MudSpacer />
        @if (!_isAgentOnly)
        {
            <AuthorizeView>
                <MudTooltip Text="Trợ lý AI">
                    <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Inherit" Href="/ai" />
                </MudTooltip>
            </AuthorizeView>
        }
        <MudTooltip Text="@(_isDarkMode ? "Chế độ sáng" : "Chế độ tối")">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" OnClick="ToggleDarkModeAsync" />
        </MudTooltip>
        <AuthorizeView>
            <NotificationBell />
            <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                <div class="px-4 py-2">
                    <MudText Typo="Typo.body2"><b>@context.User.Identity?.Name</b></MudText>
                    <MudText Typo="Typo.caption">@RoleLabel(context)</MudText>
                </div>
                <MudDivider />
                <form method="post" action="/Account/Logout">
                    <AntiforgeryToken />
                    <button type="submit" class="logout-btn">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Class="mr-2" /> Đăng xuất
                    </button>
                </form>
            </MudMenu>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="px-2 px-sm-4 py-4">
            @Body
            <AppFooter />
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Đã xảy ra lỗi không mong muốn.
    <a href="." class="reload">Tải lại</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _isAgentOnly;
    private MudThemeProvider _themeProvider = default!;

    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    protected override async Task OnParametersSetAsync()
    {
        var scope = await AgentScope.GetAsync();
        _isAgentOnly = scope.IsAgentOnly;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Mặc định SÁNG (tươi sáng theo nhận diện thương hiệu); chỉ tối khi user tự chọn.
        var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "polymind-theme");
        _isDarkMode = saved == "dark";

        // Mobile mở app: drawer đóng (overlay); laptop: mở sẵn.
        var bp = await Viewport.GetCurrentBreakpointAsync();
        _drawerOpen = bp >= Breakpoint.Md;

        StateHasChanged();
    }

    // Trên mobile (drawer là overlay), tự đóng menu sau khi điều hướng.
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var bp = await Viewport.GetCurrentBreakpointAsync();
        if (bp < Breakpoint.Md && _drawerOpen)
        {
            _drawerOpen = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ToggleDarkModeAsync()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "polymind-theme", _isDarkMode ? "dark" : "light");
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private static string RoleLabel(AuthenticationState ctx)
        => ctx.User.IsInRole("super_admin") ? "Super Admin" : "Người dùng";
}
