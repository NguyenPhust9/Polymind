<MudNavMenu>
    @if (!_isPartnerOnly)
    {
        <AuthorizeView Policy="dashboard:read">
            <Authorized>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Tổng quan</MudNavLink>
            </Authorized>
        </AuthorizeView>
    }
    <AuthorizeView Policy="leads:read">
        <Authorized>
            <MudNavLink Href="/leads" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ContactPhone">Lead (CRM)</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="candidates:read">
        <Authorized>
            <MudNavLink Href="/candidates" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Groups">Ứng viên</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="job_orders:read">
        <Authorized>
            <MudNavLink Href="/jobs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.WorkOutline">Jobs</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="payments:read">
        <Authorized>
            <MudNavLink Href="/finance" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Payments">Tài chính</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="loans:read">
        <Authorized>
            <MudNavLink Href="/loans" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalance">Hỗ trợ vay</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="agents:read">
        <Authorized>
            <MudNavLink Href="/agents" Match="NavLinkMatch.Prefix" Icon="@(_isPartnerOnly ? Icons.Material.Filled.EmojiEvents : Icons.Material.Filled.Handshake)">@(_isPartnerOnly ? "Bảng thi đua doanh số" : "Đại lý & Hoa hồng")</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="visas:read">
        <Authorized>
            <MudNavLink Href="/visa" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FlightTakeoff">Visa &amp; Xuất cảnh</MudNavLink>
        </Authorized>
    </AuthorizeView>
    @if (_isPartnerOnly)
    {
        <AuthorizeView Policy="commissions:read">
            <Authorized>
                <MudNavLink Href="/my-commissions" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Paid">Hoa hồng của tôi</MudNavLink>
            </Authorized>
        </AuthorizeView>
    }
    else
    {
        <AuthorizeView Policy="reports:read">
            <Authorized>
                <MudNavLink Href="/reports" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Assessment">Báo cáo</MudNavLink>
            </Authorized>
        </AuthorizeView>
    }
    <AuthorizeView Policy="messages:read">
        <Authorized>
            <MudNavLink Href="/messages" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Forum">Tin nhắn</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Policy="notifications:read">
        <Authorized>
            <MudNavLink Href="/notifications" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Notifications">Thông báo</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <MudNavLink Href="/guide" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook">Hướng dẫn sử dụng</MudNavLink>
    @if (!_isPartnerOnly)
    {
        <AuthorizeView Policy="users:read">
            <Authorized>
                <MudNavLink Href="/admin" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings">Quản trị</MudNavLink>
            </Authorized>
        </AuthorizeView>
    }
</MudNavMenu>

@code {
    [Inject] private AgentScope AgentScope { get; set; } = default!;
    private bool _isPartnerOnly;

    protected override async Task OnInitializedAsync()
    {
        var scope = await AgentScope.GetAsync();
        _isPartnerOnly = scope.IsPartnerOnly;
    }
}
