@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Polymind.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>Đăng nhập — POLYMIND</PageTitle>

<div class="login-page">
    <div class="login-shell">
        <section class="login-hero">
            <div class="login-hero-brand">
                <span class="login-logo"><img src="img/logo-polymind.png?v=20260629-logo2" alt="POLYMIND" /></span>
                <div>
                    <h2>POLYMIND OLMS</h2>
                    <span class="login-hero-tag">QUẢN LÝ XUẤT KHẨU LAO ĐỘNG</span>
                </div>
            </div>
            <span class="pm-eyebrow login-hero-eyebrow">VẬN HÀNH THÔNG MINH</span>
            <h1 class="login-hero-title">Quản lý trọn hành trình xuất khẩu lao động.</h1>
            <p class="login-hero-sub">Lead · Ứng viên · Đơn hàng · Tài chính · Visa.</p>
        </section>

        <div class="login-card">
            <span class="pm-eyebrow">CHÀO MỪNG TRỞ LẠI</span>
            <h2 class="login-card-title">Đăng nhập hệ thống</h2>
            <p class="login-card-sub">Sử dụng tài khoản được cấp.</p>

            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="login-error">@_error</div>
                }

                <label class="login-label">Email</label>
                <InputText @bind-Value="Input.Email" class="login-input" placeholder="Nhập email đăng nhập" autocomplete="username" />
                <ValidationMessage For="() => Input.Email" />

                <label class="login-label">Mật khẩu</label>
                <div class="login-pwd-wrap">
                    <InputText type="password" id="login-password" @bind-Value="Input.Password" class="login-input" placeholder="••••••••" autocomplete="current-password" />
                    <button type="button" class="login-pwd-toggle" tabindex="-1" aria-label="Hiện/ẩn mật khẩu"
                            onclick="(function(b){var i=document.getElementById('login-password');var s=b.querySelector('.eye-show'),h=b.querySelector('.eye-hide');if(i.type==='password'){i.type='text';s.style.display='none';h.style.display='inline-flex';}else{i.type='password';s.style.display='inline-flex';h.style.display='none';}})(this)">
                        <svg class="eye-show" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zm0 12.5c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
                        <svg class="eye-hide" style="display:none" viewBox="0 0 24 24"><path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2z"/></svg>
                    </button>
                </div>
                <ValidationMessage For="() => Input.Password" />

                <button type="submit" class="login-btn">Đăng nhập →</button>
            </EditForm>

            <p class="login-help">Cần hỗ trợ? Liên hệ quản trị hệ thống.</p>
        </div>
    </div>

    <AppFooter />
</div>

@code {
    [SupplyParameterFromForm] private LoginInput Input { get; set; } = default!;
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    private string? _error;

    protected override void OnInitialized()
    {
        Input ??= new LoginInput();
    }

    private async Task LoginUser()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is not null && !user.IsActive)
        {
            _error = "Tài khoản đang bị khóa. Vui lòng liên hệ quản trị viên.";
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, isPersistent: true, lockoutOnFailure: true);
        if (result.Succeeded)
        {
            if (user is not null)
            {
                user.LastLoginAt = DateTimeOffset.UtcNow;
                await UserManager.UpdateAsync(user);
            }
            Nav.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
        }
        else if (result.RequiresTwoFactor)
        {
            // Đúng mật khẩu + tài khoản đã bật 2FA → sang bước nhập mã Authenticator.
            var returnUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
            Nav.NavigateTo($"/login-2fa?ReturnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
        }
        else if (result.IsLockedOut)
            _error = "Tài khoản tạm khóa do đăng nhập sai nhiều lần. Vui lòng thử lại sau 15 phút.";
        else
            _error = "Email hoặc mật khẩu không đúng.";
    }

    private sealed class LoginInput
    {
        [Required(ErrorMessage = "Vui lòng nhập email")]
        [EmailAddress(ErrorMessage = "Email không hợp lệ")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập mật khẩu")]
        public string Password { get; set; } = "";
    }
}
