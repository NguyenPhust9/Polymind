@inject IDbContextFactory<ApplicationDbContext> DbFactory

@* Bảng thông tin nhanh về 1 cộng tác viên — để liên lạc. *@
<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_ctv is null)
        {
            <MudAlert Severity="Severity.Warning">Không tìm thấy cộng tác viên.</MudAlert>
        }
        else
        {
            <div class="d-flex align-center mb-3" style="gap:12px">
                <MudAvatar Color="Color.Primary" Size="Size.Large">@Initials(_ctv.FullName)</MudAvatar>
                <div style="min-width:0">
                    <MudText Typo="Typo.h6"><b>@_ctv.FullName</b></MudText>
                    <div class="d-flex align-center" style="gap:8px">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@_ctv.Code</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@(_ctv.IsActive ? Color.Success : Color.Default)">
                            @(_ctv.IsActive ? "Đang hoạt động" : "Ngừng")
                        </MudChip>
                    </div>
                </div>
            </div>
            <MudDivider Class="mb-3" />
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Storefront">Đại lý: <b>@_agentName</b></MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Phone">
                    @if (!string.IsNullOrWhiteSpace(_ctv.Phone))
                    {
                        <MudLink Href="@($"tel:{_ctv.Phone}")">@_ctv.Phone</MudLink>
                    }
                    else { <span>—</span> }
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Email">
                    @if (!string.IsNullOrWhiteSpace(_ctv.Email))
                    {
                        <MudLink Href="@($"mailto:{_ctv.Email}")">@_ctv.Email</MudLink>
                    }
                    else { <span>—</span> }
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Place">@(string.IsNullOrWhiteSpace(_ctv.Address) ? "—" : _ctv.Address)</MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Groups">Ứng viên đã giới thiệu: <b>@_candidateCount</b></MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Percent">Tỷ lệ hoa hồng CTV: <b>@($"{_ctv.CommissionSharePercentage:0.#}%")</b></MudListItem>
                @if (!string.IsNullOrWhiteSpace(_ctv.Note))
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Notes">@_ctv.Note</MudListItem>
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close())">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Guid CollaboratorId { get; set; }

    private Collaborator? _ctv;
    private string _agentName = "—";
    private int _candidateCount;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _ctv = await db.Collaborators.FirstOrDefaultAsync(c => c.Id == CollaboratorId);
        if (_ctv is not null)
        {
            _agentName = await db.Agents.Where(a => a.Id == _ctv.AgentId).Select(a => a.Name).FirstOrDefaultAsync() ?? "—";
            _candidateCount = await db.Candidates.CountAsync(c => c.CollaboratorId == CollaboratorId);
        }
        _loading = false;
    }

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        return parts.Length == 1 ? parts[0][..1].ToUpper() : $"{parts[^2][0]}{parts[^1][0]}".ToUpper();
    }
}
