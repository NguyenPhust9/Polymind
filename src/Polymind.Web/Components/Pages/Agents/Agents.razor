@page "/agents"
@attribute [Authorize(Policy = "agents:read")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthStateProvider
@inject AgentScope AgentScope

<PageTitle>@_pageTitle — POLYMIND</PageTitle>

<PageHeader Eyebrow="@_pageEyebrow" Title="@_pageTitle" Subtitle="@_pageSubtitle">
    <Actions>
        <MudSelect T="int" Value="_selectedMonth" ValueChanged="OnMonthChanged"
                   Label="Tháng thi đua" Variant="Variant.Outlined" Margin="Margin.Dense"
                   Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CalendarMonth" Style="min-width:160px">
            @foreach (var month in Enumerable.Range(1, 12))
            {
                <MudSelectItem T="int" Value="@month" Disabled="@IsFutureMonth(month)">Tháng @month</MudSelectItem>
            }
        </MudSelect>
        @if (!_isPartnerOnly)
        {
            <AuthorizeView Policy="agents:create">
                <Authorized>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">
                        Thêm đại lý
                    </MudButton>
                </Authorized>
            </AuthorizeView>
        }
    </Actions>
</PageHeader>

@* ===== Bảng thi đua 1: Doanh số đại lý ===== *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <div class="d-flex align-center mb-3" style="gap:8px">
        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" />
        <MudText Typo="Typo.subtitle1"><b>Bảng thi đua — Top 3 Đại lý doanh thu cao nhất</b></MudText>
    </div>
    @if (_agentBoard.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">Chưa có dữ liệu đại lý.</MudAlert>
    }
    else
    {
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th style="width:48px">#</th>
                        <th>Đại lý</th>
                        <th style="text-align:center">CTV</th>
                        <th style="text-align:center" title="Ứng viên đạt bước Đặt cọc trong tháng đang lọc">Ứng viên đặt cọc</th>
                        <th style="text-align:right">Hoa hồng</th>
                        <th style="text-align:right">Doanh số (đã thu)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _agentBoard)
                    {
                        <tr class="@AgentBoardRowClass(a)" style="@AgentRowStyle" @onclick="@(() => OpenAgentDetail(a.Id))">
                            <td>@RankBadge(a.Rank)</td>
                            <td>
                                <div class="d-flex align-center flex-wrap" style="gap:6px">
                                    <b>@a.Name</b>
                                    @if (a.IsMine)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Tôi</MudChip>
                                    }
                                    else if (a.IsMyAgency)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Đại lý của tôi</MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">@a.Code</MudText>
                            </td>
                            <td style="text-align:center">@a.CollaboratorCount</td>
                            <td style="text-align:center">@a.CandidateCount</td>
                            <td style="text-align:right">@($"{a.Commission:N0} đ")</td>
                            <td style="text-align:right"><Money Amount="a.Revenue" /></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudHidden>
        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
            @foreach (var a in _agentBoard)
            {
                <MudPaper Class="@($"mobile-card pa-3 {AgentBoardCardClass(a)}")" Elevation="0" Style="@AgentRowStyle" @onclick="@(() => OpenAgentDetail(a.Id))">
                    <div class="d-flex align-center" style="gap:10px">
                        @RankBadge(a.Rank)
                        <div style="min-width:0;flex:1">
                            <div class="d-flex align-center flex-wrap" style="gap:6px">
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600">@a.Name</MudText>
                                @if (a.IsMine)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Tôi</MudChip>
                                }
                                else if (a.IsMyAgency)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Đại lý của tôi</MudChip>
                                }
                            </div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.CollaboratorCount CTV • @a.CandidateCount ứng viên đặt cọc trong tháng</MudText>
                        </div>
                        <Money Amount="a.Revenue" />
                    </div>
                </MudPaper>
            }
        </MudHidden>
    }
</MudPaper>

@* ===== Bảng thi đua 2: Doanh số CTV (mọi đại lý) ===== *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <div class="d-flex align-center mb-3" style="gap:8px">
        <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Color="Color.Secondary" />
        <MudText Typo="Typo.subtitle1"><b>Bảng thi đua — Top 5 Cộng tác viên doanh thu cao nhất</b></MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary">(bấm tên CTV để xem thông tin liên lạc)</MudText>
    </div>
    @if (_ctvBoard.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">Chưa có cộng tác viên.</MudAlert>
    }
    else
    {
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th style="width:48px">#</th>
                        <th>Cộng tác viên</th>
                        <th>Đại lý</th>
                        <th style="text-align:center" title="Ứng viên đạt bước Đặt cọc trong tháng đang lọc">Ứng viên đặt cọc</th>
                        <th style="text-align:center">Trạng thái</th>
                        <th style="text-align:right">Doanh số (đã thu)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _ctvBoard)
                    {
                        <tr class="@CtvBoardRowClass(c)">
                            <td>@RankBadge(c.Rank)</td>
                            <td>
                                <div class="d-flex align-center flex-wrap" style="gap:6px">
                                    <span class="chip-clickable" @onclick="@(() => ShowCtv(c.Id))" @onclick:stopPropagation="true">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Diversity3">CTV-@c.FullName</MudChip>
                                    </span>
                                    @if (c.IsMine)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Tôi</MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">@c.Code</MudText>
                            </td>
                            <td>@c.AgentName</td>
                            <td style="text-align:center">@c.CandidateCount</td>
                            <td style="text-align:center">
                                <MudChip T="string" Size="Size.Small" Color="@(c.IsActive ? Color.Success : Color.Default)">@(c.IsActive ? "Hoạt động" : "Ngừng")</MudChip>
                            </td>
                            <td style="text-align:right"><Money Amount="c.Revenue" /></td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudHidden>
        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
            @foreach (var c in _ctvBoard)
            {
                <MudPaper Class="@($"mobile-card pa-3 {CtvBoardCardClass(c)}")" Elevation="0">
                    <div class="d-flex align-center" style="gap:10px">
                        @RankBadge(c.Rank)
                        <div style="min-width:0;flex:1">
                            <div class="d-flex align-center flex-wrap" style="gap:6px">
                                <span class="chip-clickable" @onclick="@(() => ShowCtv(c.Id))">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Diversity3">CTV-@c.FullName</MudChip>
                                </span>
                                @if (c.IsMine)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Tôi</MudChip>
                                }
                            </div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">@c.AgentName • @c.CandidateCount ứng viên đặt cọc trong tháng</MudText>
                        </div>
                        <Money Amount="c.Revenue" />
                    </div>
                </MudPaper>
            }
        </MudHidden>
    }
</MudPaper>

@if (!_isPartnerOnly)
{
    @* ===== Danh sách đại lý (điều hướng chi tiết) ===== *@
    <MudPaper Elevation="1" Class="pa-4">
        <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Danh sách đại lý</b></MudText>
        <MudTextField @bind-Value="_search" Placeholder="Tìm tên, mã, SĐT..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />

        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudDataGrid T="Agent" Items="Filtered" Hover="true" Dense="true" Striped="true"
                         RowClick="@(args => Nav.NavigateTo($"/agents/{args.Item.Id}"))" Class="cursor-pointer">
                <Columns>
                    <PropertyColumn Property="x => x.Code" Title="Mã" />
                    <PropertyColumn Property="x => x.Name" Title="Tên đại lý" />
                    <PropertyColumn Property="x => x.RepresentativeName" Title="Người đại diện" />
                    <PropertyColumn Property="x => x.Phone" Title="SĐT" />
                    <TemplateColumn Title="Trạng thái">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                                @(context.Item.IsActive ? "Đang hợp tác" : "Ngừng")
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent><MudDataGridPager T="Agent" /></PagerContent>
            </MudDataGrid>
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
            @if (!Filtered.Any())
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary py-4" Align="Align.Center">Không có đại lý phù hợp.</MudText>
            }
            else
            {
                @foreach (var a in Filtered)
                {
                    <MudPaper Class="mobile-card pa-3" Elevation="0" Style="cursor:pointer" @onclick="@(() => Nav.NavigateTo($"/agents/{a.Id}"))">
                        <div class="d-flex justify-space-between align-center" style="gap:8px">
                            <div style="min-width:0">
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600">@a.Name</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Code • @(string.IsNullOrWhiteSpace(a.Phone) ? "—" : a.Phone)</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="@(a.IsActive ? Color.Success : Color.Default)">@(a.IsActive ? "Đang hợp tác" : "Ngừng")</MudChip>
                        </div>
                    </MudPaper>
                }
            }
        </MudHidden>
    </MudPaper>
}

@code {
    private record AgentBoardRow(Guid Id, string Code, string Name, int CollaboratorCount, int CandidateCount, decimal Commission, decimal Revenue)
    {
        public int Rank { get; init; }
        public bool IsMine { get; init; }
        public bool IsMyAgency { get; init; }
    }

    private record CtvBoardRow(Guid Id, string Code, string FullName, string AgentName, bool IsActive, int CandidateCount, decimal Revenue)
    {
        public int Rank { get; init; }
        public bool IsMine { get; init; }
    }

    private List<Agent> _agents = new();
    private List<AgentBoardRow> _agentBoard = new();
    private List<CtvBoardRow> _ctvBoard = new();
    private int _agentTotal;
    private int _ctvTotal;
    private string _search = "";
    private bool _isPartnerOnly;
    private readonly int _currentYear = DateTime.Today.Year;
    private readonly int _currentMonth = DateTime.Today.Month;
    private int _selectedMonth = DateTime.Today.Month;
    private string _pageTitle = "Đại lý và Cộng tác viên";
    private string _pageEyebrow = "HOA HỒNG";
    private string _pageSubtitle = "";
    private string _partnerScopeLabel = "";
    private Guid? _currentAgentId;
    private Guid? _currentCollaboratorId;
    private bool _isCollaboratorOnly;
    private string AgentRowStyle => _isPartnerOnly ? "" : "cursor:pointer";

    private IEnumerable<Agent> Filtered => _agents.Where(a =>
        string.IsNullOrWhiteSpace(_search)
        || a.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
        || a.Code.Contains(_search, StringComparison.OrdinalIgnoreCase)
        || (a.Phone?.Contains(_search) ?? false));

    protected override async Task OnInitializedAsync()
    {
        var scope = await AgentScope.GetAsync();
        _isPartnerOnly = scope.IsPartnerOnly;
        _isCollaboratorOnly = scope.IsCollaboratorOnly;
        _currentAgentId = scope.AgentId;
        _currentCollaboratorId = scope.CollaboratorId;
        _partnerScopeLabel = BuildPartnerScopeLabel(scope);
        _pageTitle = _isPartnerOnly ? "Bảng thi đua doanh số" : "Đại lý và Cộng tác viên";
        _pageEyebrow = _isPartnerOnly ? "THI ĐUA" : "HOA HỒNG";
        await Load();
    }

    private bool IsFutureMonth(int month) => _currentYear == DateTime.Today.Year && month > _currentMonth;

    private async Task OnMonthChanged(int month)
    {
        if (IsFutureMonth(month)) return;
        _selectedMonth = month;
        await Load();
    }

    private async Task Load()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _agents = await db.Agents.OrderBy(a => a.Name).ToListAsync();
        var ctvs = await db.Collaborators.ToListAsync();
        var cands = await db.Candidates.Select(c => new { c.Id, c.AgentId, c.CollaboratorId }).ToListAsync();
        var monthStart = new DateOnly(_currentYear, _selectedMonth, 1);
        var monthEnd = monthStart.AddMonths(1);
        var commissionStart = new DateTimeOffset(monthStart.ToDateTime(TimeOnly.MinValue), TimeSpan.Zero);
        var commissionEnd = new DateTimeOffset(monthEnd.ToDateTime(TimeOnly.MinValue), TimeSpan.Zero);

        var paidByCandidate = await db.Payments
            .Where(p => p.Status == PaymentStatus.Paid)
            .Where(p => p.PaidDate >= monthStart && p.PaidDate < monthEnd)
            .GroupBy(p => p.CandidateId)
            .Select(g => new { CandidateId = g.Key, Sum = g.Sum(x => x.Amount) })
            .ToDictionaryAsync(x => x.CandidateId, x => x.Sum);
        var commissionByAgent = await db.AgentCommissions
            .Where(c => c.CreatedAt >= commissionStart && c.CreatedAt < commissionEnd)
            .GroupBy(c => c.AgentId)
            .Select(g => new { AgentId = g.Key, Sum = g.Sum(x => x.CommissionAmount) })
            .ToDictionaryAsync(x => x.AgentId, x => x.Sum);

        // Cột "Ứng viên" = ứng viên ĐẶT CỌC trong tháng đang lọc (bước Đặt cọc hoàn thành
        // trong tháng — cùng thời điểm đại lý/CTV phát sinh hoa hồng). Sang tháng mới chưa có
        // ai đặt cọc thì cột về 0.
        var depositCandidateIds = (await db.WorkflowStepRecords
            .Where(r => r.Step == WorkflowStep.Deposit
                        && r.Status == WorkflowStepStatus.Completed
                        && r.CompletedAt >= commissionStart && r.CompletedAt < commissionEnd)
            .Select(r => r.CandidateJobOrder.CandidateId)
            .ToListAsync())
            .ToHashSet();

        decimal RevenueOfCandidate(Guid id) => paidByCandidate.GetValueOrDefault(id, 0m);

        // Bảng đại lý
        var rankedAgents = _agents.Select(a =>
        {
            var agentCands = cands.Where(c => c.AgentId == a.Id).ToList();
            return new AgentBoardRow(
                a.Id, a.Code, a.Name,
                ctvs.Count(c => c.AgentId == a.Id && c.IsActive),
                agentCands.Count(c => depositCandidateIds.Contains(c.Id)),
                commissionByAgent.GetValueOrDefault(a.Id, 0m),
                agentCands.Sum(c => RevenueOfCandidate(c.Id)));
        })
        .OrderByDescending(x => x.Revenue).ThenByDescending(x => x.CandidateCount)
        .Select((row, index) => row with
        {
            Rank = index + 1,
            IsMine = !_isCollaboratorOnly && _currentAgentId == row.Id,
            IsMyAgency = _isCollaboratorOnly && _currentAgentId == row.Id
        })
        .ToList();
        _agentBoard = TakeTopWithPinned(rankedAgents, 3, row => row.IsMine || row.IsMyAgency);

        // Bảng CTV
        var agentNames = _agents.ToDictionary(a => a.Id, a => a.Name);
        var rankedCtvs = ctvs.Select(c =>
        {
            var ctvCands = cands.Where(x => x.CollaboratorId == c.Id).ToList();
            return new CtvBoardRow(
                c.Id, c.Code, c.FullName,
                agentNames.GetValueOrDefault(c.AgentId, "—"),
                c.IsActive,
                ctvCands.Count(x => depositCandidateIds.Contains(x.Id)),
                ctvCands.Sum(x => RevenueOfCandidate(x.Id)));
        })
        .OrderByDescending(x => x.Revenue).ThenByDescending(x => x.CandidateCount)
        .Select((row, index) => row with
        {
            Rank = index + 1,
            IsMine = _currentCollaboratorId == row.Id
        })
        .ToList();
        _ctvBoard = TakeTopWithPinned(rankedCtvs, 5, row => row.IsMine);

        _agentTotal = _agents.Count;
        _ctvTotal = ctvs.Count;
        _pageSubtitle = string.IsNullOrWhiteSpace(_partnerScopeLabel)
            ? $"{_agentTotal} đại lý • {_ctvTotal} cộng tác viên • Tháng {_selectedMonth}/{_currentYear}"
            : $"{_partnerScopeLabel} • Tháng {_selectedMonth}/{_currentYear}";
    }

    private static List<T> TakeTopWithPinned<T>(IReadOnlyList<T> rows, int count, Func<T, bool> isPinned)
        where T : class
    {
        var board = rows.Take(count).ToList();
        var pinned = rows.FirstOrDefault(isPinned);
        if (pinned is not null && !board.Contains(pinned))
            board.Add(pinned);

        return board;
    }

    private static string BuildPartnerScopeLabel(AgentScopeInfo scope)
    {
        if (scope.IsCollaboratorOnly)
        {
            var collaborator = string.IsNullOrWhiteSpace(scope.CollaboratorName) ? "CTV của tôi" : $"CTV {scope.CollaboratorName}";
            return scope.AgentName is null ? collaborator : $"{collaborator} • Đại lý {scope.AgentName}";
        }

        if (scope.IsAgentOnly)
            return string.IsNullOrWhiteSpace(scope.AgentName) ? "Đại lý của tôi" : scope.AgentName;

        return "";
    }

    private static string AgentBoardRowClass(AgentBoardRow row)
        => row.IsMine ? "partner-self-row" : row.IsMyAgency ? "partner-related-row" : "";

    private static string AgentBoardCardClass(AgentBoardRow row)
        => row.IsMine ? "partner-self-card" : row.IsMyAgency ? "partner-related-card" : "";

    private static string CtvBoardRowClass(CtvBoardRow row) => row.IsMine ? "partner-self-row" : "";

    private static string CtvBoardCardClass(CtvBoardRow row) => row.IsMine ? "partner-self-card" : "";

    private void OpenAgentDetail(Guid id)
    {
        if (_isPartnerOnly) return;
        Nav.NavigateTo($"/agents/{id}");
    }

    private async Task ShowCtv(Guid id)
    {
        var parameters = new DialogParameters<CollaboratorInfoDialog> { { x => x.CollaboratorId, id } };
        await DialogService.ShowAsync<CollaboratorInfoDialog>("Thông tin cộng tác viên", parameters);
    }

    private async Task OpenCreate()
    {
        if (!await HasPermission("agents:create"))
        {
            Snackbar.Add("Bạn không có quyền tạo đại lý.", Severity.Warning);
            return;
        }

        var dialog = await DialogService.ShowAsync<AgentDialog>("Thêm đại lý mới");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Đã thêm đại lý mới", Severity.Success);
            await Load();
        }
    }

    private async Task<bool> HasPermission(string permission)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded;
    }

    private RenderFragment RankBadge(int rank) =>@<span class="rank-badge @(rank == 1 ? "rank-1" : rank == 2 ? "rank-2" : rank == 3 ? "rank-3" : "rank-n")">@rank</span>;
}
