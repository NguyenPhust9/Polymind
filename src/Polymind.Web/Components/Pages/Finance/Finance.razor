    private async Task HandleResult(IDialogReference dialog, string successMessage)
    {
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add(successMessage, Severity.Success);
            await Load();
        }
    }

    private async Task<bool> HasPermission(string permission)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded;
    }

    private async Task<bool> CanRecordPayment()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole(RoleNames.Director))
            return false;

        var canUpdate = await AuthorizationService.AuthorizeAsync(authState.User, null, "payments:update");
        var canApprove = await AuthorizationService.AuthorizeAsync(authState.User, null, "payments:approve");
        return canUpdate.Succeeded && canApprove.Succeeded;
    }
