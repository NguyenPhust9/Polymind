@using Microsoft.AspNetCore.Identity
@using Polymind.Infrastructure.Identity
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState

@* Dialog xác nhận thao tác nhạy cảm (đổi vai trò...): bắt người thao tác nhập lại mật khẩu của chính mình. *@
<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">@Message</MudAlert>
        <MudTextField @bind-Value="_password" Label="Nhập lại mật khẩu của bạn để xác nhận"
                      Variant="Variant.Outlined" Margin="Margin.Dense" AutoFocus="true"
                      InputType="@(_show ? InputType.Text : InputType.Password)"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_show ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="@(() => _show = !_show)" />
        @if (!string.IsNullOrEmpty(_error))
        {
            <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">@_error</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Hủy</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" Disabled="_checking" OnClick="ConfirmAsync">Xác nhận</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Mô tả thao tác sắp thực hiện, hiển thị trong cảnh báo.</summary>
    [Parameter] public string Message { get; set; } = "Thao tác nhạy cảm — cần xác nhận danh tính.";

    private string _password = "";
    private string? _error;
    private bool _show;
    private bool _checking;

    private async Task ConfirmAsync()
    {
        if (string.IsNullOrEmpty(_password))
        {
            _error = "Vui lòng nhập mật khẩu.";
            return;
        }

        _checking = true;
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var actor = await UserManager.GetUserAsync(authState.User);
            if (actor is null || !await UserManager.CheckPasswordAsync(actor, _password))
            {
                _error = "Mật khẩu không đúng.";
                return;
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _checking = false;
        }
    }
}
