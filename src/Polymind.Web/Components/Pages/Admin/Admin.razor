    private IEnumerable<(string Key, string Label, string Icon, Color Color, List<UserRow> Users)> GroupedUsers()
    {
        foreach (var (role, label, icon, color) in RoleOrder)
            yield return (role, label, icon, color, _users.Where(u => u.PrimaryRole == role).ToList());

        var known = RoleOrder.Select(r => r.Role).ToHashSet();
        var others = _users.Where(u => u.PrimaryRole is null || !known.Contains(u.PrimaryRole)).ToList();
        if (others.Count > 0)
            yield return ("", "Chưa gán vai trò", Icons.Material.Filled.HelpOutline, Color.Default, others);
    }

