    private static string? ShortTechnicalId(Guid? id)
        => id is null ? null : id.Value.ToString("N")[..8].ToUpperInvariant();

    private static string NormalizeAuditFilter(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "";
        var text = value.Trim().ToLowerInvariant();
        return text switch
        {
            "tài khoản" or "tai khoan" or "user" => "users",
            "ứng viên" or "ung vien" => "candidates",
            "lead" => "leads",
            "đơn hàng" or "don hang" or "job" => "job_orders",
            "khoản thu" or "khoan thu" or "thu" => "payments",
            "khoản chi" or "khoan chi" or "chi" => "expenses",
            "hoa hồng" or "hoa hong" => "agent_commissions",
            "thêm" or "them" => "create",
            "sửa" or "sua" or "cập nhật" or "cap nhat" => "update",
            "xóa" or "xoa" => "delete",
            "duyệt" or "duyet" => "approve",
            _ => text
        };
    }

    private static string HumanizeTechnicalName(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "Không rõ";
        var text = value.Replace('_', ' ').Replace('-', ' ').Trim();
        return string.Join(' ', text.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(word => word.Length == 0 ? word : char.ToUpperInvariant(word[0]) + word[1..]));
    }

