@using Microsoft.AspNetCore.Identity
@using Polymind.Infrastructure.Identity
@using Polymind.Web.Identity
@inject UserManager<ApplicationUser> UserManager
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject TwoFactorStatusCache TwoFactorCache

@* Dialog cho super admin chỉnh sửa 1 tài khoản: họ tên, tên đăng nhập (email), mật khẩu. *@
<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (!_found)
        {
            <MudAlert Severity="Severity.Warning">Không tìm thấy tài khoản.</MudAlert>
        }
        else
        {
            <MudTextField @bind-Value="_fullName" Label="Họ tên" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
            <MudTextField @bind-Value="_email" Label="Tên đăng nhập (email)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
            <MudTextField @bind-Value="_password" Label="Mật khẩu mới" HelperText="Để trống nếu không đổi mật khẩu"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="@(() => _showPassword = !_showPassword)" />

            <MudDivider Class="my-3" />
            <div class="d-flex align-center justify-space-between flex-wrap" style="gap:8px">
                <div>
                    <MudText Typo="Typo.subtitle2"><b>Xác thực 2 lớp (2FA)</b></MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @(_twoFactorEnabled ? "Đang bật — nhân viên mất điện thoại thì đặt lại tại đây." : "Chưa bật — hệ thống sẽ yêu cầu cài ở lần đăng nhập tới.")
                    </MudText>
                </div>
                @if (_twoFactorEnabled)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.PhonelinkErase" OnClick="ResetTwoFactorAsync" Disabled="_saving">
                        Đặt lại 2FA
                    </MudButton>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving || !_found" OnClick="SaveAsync">Lưu thay đổi</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Guid UserId { get; set; }

    private bool _loading = true;
    private bool _saving;
    private bool _found;
    private bool _showPassword;
    private bool _twoFactorEnabled;
    private string _fullName = "";
    private string _email = "";
    private string _password = "";

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.FindByIdAsync(UserId.ToString());
        if (user is not null)
        {
            _found = true;
            _fullName = user.FullName;
            _email = user.Email ?? user.UserName ?? "";
            _twoFactorEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
        }
        _loading = false;
    }

    // Nhân viên mất điện thoại/mã khôi phục: tắt 2FA + hủy key cũ → lần đăng nhập tới hệ thống bắt cài lại từ đầu.
    private async Task ResetTwoFactorAsync()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Đặt lại 2FA?",
            $"Tắt xác thực 2 lớp của \"{_fullName}\" và hủy key cũ. Lần đăng nhập tới, tài khoản này sẽ phải quét QR cài lại 2FA. Bạn có chắc chắn?",
            yesText: "Đặt lại", cancelText: "Hủy");
        if (confirm != true) return;

        _saving = true;
        try
        {
            var user = await UserManager.FindByIdAsync(UserId.ToString());
            if (user is null)
            {
                Snackbar.Add("Không tìm thấy tài khoản.", Severity.Error);
                return;
            }

            await UserManager.SetTwoFactorEnabledAsync(user, false);
            await UserManager.ResetAuthenticatorKeyAsync(user);
            TwoFactorCache.Invalidate(user.Id.ToString());

            await using var db = await DbFactory.CreateDbContextAsync();
            db.AddAudit(await AuthState.GetUserIdAsync(), "reset_2fa", "users", user.Id,
                new { TwoFactorEnabled = true }, new { TwoFactorEnabled = false });
            await db.SaveChangesAsync();

            _twoFactorEnabled = false;
            Snackbar.Add("Đã đặt lại 2FA — tài khoản sẽ cài lại ở lần đăng nhập tới.", Severity.Success);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_fullName) || string.IsNullOrWhiteSpace(_email))
        {
            Snackbar.Add("Vui lòng nhập họ tên và tên đăng nhập.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var user = await UserManager.FindByIdAsync(UserId.ToString());
            if (user is null)
            {
                Snackbar.Add("Không tìm thấy tài khoản.", Severity.Error);
                return;
            }

            var oldEmail = user.Email;
            var oldFullName = user.FullName;
            var newEmail = _email.Trim();
            var emailChanged = !string.Equals(oldEmail, newEmail, StringComparison.OrdinalIgnoreCase);

            user.FullName = _fullName.Trim();
            var update = await UserManager.UpdateAsync(user);
            if (!update.Succeeded)
            {
                Snackbar.Add(string.Join("; ", update.Errors.Select(e => e.Description)), Severity.Error);
                return;
            }

            if (emailChanged)
            {
                var setEmail = await UserManager.SetEmailAsync(user, newEmail);
                if (!setEmail.Succeeded)
                {
                    Snackbar.Add(string.Join("; ", setEmail.Errors.Select(e => e.Description)), Severity.Error);
                    return;
                }
                var setName = await UserManager.SetUserNameAsync(user, newEmail);
                if (!setName.Succeeded)
                {
                    Snackbar.Add(string.Join("; ", setName.Errors.Select(e => e.Description)), Severity.Error);
                    return;
                }
            }

            if (!string.IsNullOrWhiteSpace(_password))
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                var reset = await UserManager.ResetPasswordAsync(user, token, _password);
                if (!reset.Succeeded)
                {
                    Snackbar.Add(string.Join("; ", reset.Errors.Select(e => e.Description)), Severity.Error);
                    return;
                }
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            db.AddAudit(await AuthState.GetUserIdAsync(), "update", "users", user.Id,
                new { Email = oldEmail, FullName = oldFullName },
                new { Email = newEmail, user.FullName, PasswordChanged = !string.IsNullOrWhiteSpace(_password) });
            await db.SaveChangesAsync();

            Snackbar.Add("Đã cập nhật tài khoản.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _saving = false;
        }
    }
}
