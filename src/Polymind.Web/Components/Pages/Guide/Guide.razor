@page "/guide"
@attribute [Authorize]
@using Polymind.Infrastructure.Persistence.Constants
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Hướng dẫn sử dụng — POLYMIND</PageTitle>

<PageHeader Eyebrow="TRỢ GIÚP" Title="Hướng dẫn sử dụng" Subtitle="Tài liệu hướng dẫn thao tác trên hệ thống POLYMIND OLMS." />

<MudAlert Severity="Severity.Info" Class="mb-4">
    <div class="guide-role-summary">
        <MudChip T="string" Color="@_profile.Color" Variant="Variant.Filled" Icon="@_profile.Icon">@_profile.Label</MudChip>
        <MudText Typo="Typo.body2">@_profile.Intro</MudText>
    </div>
</MudAlert>

<MudExpansionPanels MultiExpansion="true" Elevation="1">
    @foreach (var sec in _sections)
    {
        <MudExpansionPanel>
            <TitleContent>
                <div class="d-flex align-center" style="gap:10px">
                    <MudIcon Icon="@sec.Icon" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1"><b>@sec.Title</b></MudText>
                </div>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">@sec.Summary</MudText>
                <ul class="guide-steps">
                    @foreach (var step in sec.Steps)
                    {
                        <li><MudText Typo="Typo.body2">@step</MudText></li>
                    }
                </ul>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    <em>@sec.Note</em>
                </MudText>
            </ChildContent>
        </MudExpansionPanel>
    }
</MudExpansionPanels>

<style>
    .guide-role-summary { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .guide-steps { margin: 0 0 8px 0; padding-left: 20px; }
    .guide-steps li { margin-bottom: 6px; padding-left: 2px; }
    .guide-steps li::marker { color: var(--mud-palette-secondary); }
    .guide-steps .mud-typography { line-height: 1.55; }
</style>

@code {
