@page "/leads/{Id:guid}"
@attribute [Authorize(Policy = "leads:read")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Chi tiết Lead — POLYMIND</PageTitle>

@if (_lead is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div class="d-flex justify-space-between align-center mb-3">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/leads"))">Quay lại</MudButton>
        <div class="d-flex flex-wrap" style="gap:8px">
            @if (_canUpdateLead)
            {
                <MudButton Class="entity-action-button" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEditLead" Disabled="_busy">
                    Sửa thông tin
                </MudButton>
            }
            @if (_canDeleteLead)
            {
                <MudButton Class="entity-action-button" Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteLead" Disabled="_busy">
                    Xóa
                </MudButton>
            }
        </div>
    </div>

    @if (CareOverdueHours() is int careHours)
    {
        <MudAlert Severity="@(careHours >= CareThreshold * 2 ? Severity.Error : Severity.Warning)"
                  Icon="@Icons.Material.Filled.NotificationsActive" Class="mb-3">
            Lead đã đứng ở trạng thái "<b>@Labels.Vi(_lead.Status)</b>" @LeadCareRules.DurationLabel(careHours) —
            <b>@LeadCareRules.NextAction(_lead.Status)</b>.
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <div class="d-flex justify-space-between align-center mb-3">
                    <div>
                        <MudText Typo="Typo.h5"><b>@_lead.FullName</b></MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@_lead.Code</MudText>
                    </div>
                    <MudChip T="string" Color="Labels.ColorOf(_lead.Status)">@Labels.Vi(_lead.Status)</MudChip>
                </div>
                <MudDivider Class="mb-3" />

                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Thông tin cá nhân</b></MudText>
                <MudGrid>
                    @Field("Số điện thoại", _lead.Phone)
                    @Field("Ngày sinh", _lead.Dob?.ToString("dd/MM/yyyy"))
                    @Field("Giới tính", _lead.Gender is null ? null : Labels.Vi(_lead.Gender.Value))
                    @Field("Số CCCD", _lead.Cccd)
                    @Field("Tỉnh/Thành", _lead.Province)
                </MudGrid>
                @if (!string.IsNullOrWhiteSpace(_lead.Address))
                {
                    <MudText Typo="Typo.body2" Class="mt-2"><b>Địa chỉ:</b> @_lead.Address</MudText>
                }

                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Nguyện vọng</b></MudText>
                <MudGrid>
                    @Field("Quốc gia mong muốn", _lead.TargetCountry)
                    @Field("Đơn hàng quan tâm", _interestedJobOrder)
                </MudGrid>

                @* Thông tin nhạy cảm — chỉ super_admin được xem *@
                <AuthorizeView Roles="super_admin">
                    <Authorized>
                        <MudDivider Class="my-3" />
                        <div class="d-flex align-center mb-2" style="gap:6px">
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle2"><b>Hồ sơ chi tiết (chỉ super admin)</b></MudText>
                        </div>
                        <MudGrid>
                            @Field("Email", _lead.Email)
                            @Field("Nghề nghiệp", _lead.Occupation)
                            @Field("Trình độ học vấn", _lead.EducationLevel)
                            @Field("Kinh nghiệm làm việc", _lead.WorkExperience)
                            @Field("Ngoại ngữ", _lead.Languages)
                        </MudGrid>
                    </Authorized>
                </AuthorizeView>

                <MudDivider Class="my-3" />
                <MudGrid>
                    @Field("Nguồn", _sourceLabel)
                    @Field("Tư vấn viên", _assignedToName)
                    @Field("Lịch hẹn tư vấn", _lead.AppointmentAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))
                    @Field("Ngày tạo", _lead.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm"))
                </MudGrid>
                @if (!string.IsNullOrWhiteSpace(_lead.Notes))
                {
                    <MudText Typo="Typo.body2" Class="mt-3"><b>Ghi chú:</b> @_lead.Notes</MudText>
                }
            </MudPaper>

            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Lịch sử chăm sóc</b></MudText>
                @* Hơn 4 hoạt động → giới hạn chiều cao + cuộn riêng, để thông tin khác không bị đẩy sâu xuống. *@
                <div class="@(_activities.Count > 4 ? "lead-history-scroll" : "")">
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @for (var i = 0; i < _activities.Count; i++)
                        {
                            var a = _activities[i];
                            var isLatest = i == 0; // _activities sắp xếp mới nhất ở đầu
                            <MudTimelineItem Color="@(isLatest ? Color.Success : Color.Primary)" Size="Size.Small">
                                <div class="d-flex align-center" style="gap:6px">
                                    <MudText Typo="Typo.body2"><b>@ActivityLabel(a.ActivityType)</b></MudText>
                                    @if (isLatest)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled" Class="my-0">Mới nhất</MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption">@a.Content</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</MudText>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            @if (_canUpdateLead)
            {
                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Cập nhật trạng thái</b></MudText>
                    @if (IsConverted)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            Lead này đã chuyển thành ứng viên. Đổi trạng thái sẽ <b>chuyển ngược về Lead</b> (chỉ được khi ứng viên chưa phát sinh dữ liệu).
                        </MudAlert>
                    }
                    <MudSelect T="LeadStatus" @bind-Value="_newStatus" Label="Trạng thái mới" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                        @* "Đã chuyển" (Converted) KHÔNG cho chọn thủ công — chỉ đặt qua nút "Chuyển thành ứng viên" để chắc chắn tạo hồ sơ ứng viên. *@
                        @foreach (var s in Enum.GetValues<LeadStatus>().Where(s => s != LeadStatus.Converted))
                        {
                            <MudSelectItem Value="@s">@Labels.Vi(s)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTextField @bind-Value="_statusNote" Label="Ghi chú" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2" />
                    <MudButton Variant="Variant.Filled" Color="@(IsConverted ? Color.Warning : Color.Primary)" FullWidth="true" OnClick="UpdateStatus" Disabled="_busy">
                        @(IsConverted ? "Đổi trạng thái → chuyển ngược về Lead" : "Lưu trạng thái")
                    </MudButton>
                </MudPaper>
            }

            @if (_canUpdateLead)
            {
                @* Lead đã chuyển → khóa Phân công + Lịch hẹn (xám, bấm vào báo không thể đổi). *@
                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Phân công tư vấn viên</b></MudText>
                    <MudSelect T="Guid?" @bind-Value="_assignTo" Label="Tư vấn viên" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="mb-2" Disabled="IsConverted">
                        @foreach (var u in _users)
                        {
                            <MudSelectItem T="Guid?" Value="@u.Id">@u.FullName</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Outlined" Color="@(IsConverted ? Color.Default : Color.Primary)" FullWidth="true" OnClick="AssignLead" Disabled="_busy" Style="@(IsConverted ? "opacity:.55" : "")">Lưu phân công</MudButton>
                </MudPaper>

                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Lịch hẹn tư vấn</b></MudText>
                    <MudDatePicker @bind-Date="_appointmentDate" Label="Ngày hẹn" Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd/MM/yyyy" Class="mb-2" Disabled="IsConverted" MinDate="DateTime.Today" />
                    <MudTimePicker @bind-Time="_appointmentTime" Label="Giờ hẹn" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" Disabled="IsConverted" />
                    <MudButton Variant="Variant.Outlined" Color="@(IsConverted ? Color.Default : Color.Primary)" FullWidth="true" OnClick="SaveAppointment" Disabled="_busy" Style="@(IsConverted ? "opacity:.55" : "")">Lưu lịch hẹn</MudButton>
                    @if (_lead.AppointmentAt is not null)
                    {
                        <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">Hẹn hiện tại: <b>@_lead.AppointmentAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</b></MudText>
                    }
                </MudPaper>
            }

            @if (IsConverted)
            {
                @* Đã có hồ sơ ứng viên thật → cho xem nhanh + danh sách lead đã chuyển. *@
                <MudPaper Class="pa-4" Elevation="1">
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">Lead này đã được chuyển thành ứng viên.</MudAlert>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Person" FullWidth="true" Class="mb-2"
                               OnClick="@(() => Nav.NavigateTo($"/candidates/{_convertedCandidateId}"))">
                        Xem hồ sơ ứng viên
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.HowToReg" FullWidth="true"
                               OnClick="@(() => Nav.NavigateTo("/leads/converted"))">
                        Danh sách Lead đã chuyển thành ứng viên
                    </MudButton>
                </MudPaper>
            }
            else if (_canUpdateLead && _canCreateCandidate)
            {
                @* Chưa có hồ sơ ứng viên — kể cả khi status đã là "Đã chuyển" (lead bị kẹt do đổi trạng thái thủ công) vẫn cho tạo. *@
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-2"><b>Chuyển thành ứng viên</b></MudText>
                    <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">Tạo hồ sơ ứng viên từ lead này và bắt đầu quy trình 20 bước.</MudText>
                    @if (_lead.Status == LeadStatus.Converted)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                            Lead đang ở trạng thái "Đã chuyển" nhưng <b>chưa có hồ sơ ứng viên</b> (do đổi trạng thái thủ công). Bấm nút dưới để tạo hồ sơ.
                        </MudAlert>
                    }
                    <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.PersonAdd" FullWidth="true" OnClick="Convert" Disabled="_busy">
                        Chuyển thành ứng viên
                    </MudButton>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Lead? _lead;
    private List<LeadActivity> _activities = new();
    private LeadStatus _newStatus;
    private string _statusNote = "";
    private bool _busy;
    private bool _canUpdateLead;
    private bool _canDeleteLead;
    private bool _canCreateCandidate;
    private Guid? _assignTo;
    private DateTime? _appointmentDate;
    private TimeSpan? _appointmentTime;
    private string? _assignedToName;
    private string? _interestedJobOrder;
    private string _sourceLabel = "";
    private Guid? _convertedCandidateId;
    private bool IsConverted => _convertedCandidateId is not null;
    private record UserOption(Guid Id, string FullName);
    private List<UserOption> _users = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissions();
        await Load();
    }

    private async Task Load()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _lead = await db.Leads.FirstOrDefaultAsync(l => l.Id == Id);
        if (_lead is not null)
        {
            _newStatus = _lead.Status;
            _assignTo = _lead.AssignedTo;
            if (_lead.AppointmentAt is not null)
            {
                var local = _lead.AppointmentAt.Value.ToLocalTime();
                _appointmentDate = local.Date;
                _appointmentTime = local.TimeOfDay;
            }
            _activities = await db.LeadActivities.Where(a => a.LeadId == Id)
                .OrderByDescending(a => a.CreatedAt).ToListAsync();
            // Người phụ trách lead = tư vấn viên (role consultant).
            var consultantRoleId = await db.Roles
                .Where(r => r.Name == Polymind.Infrastructure.Persistence.Constants.RoleNames.Consultant)
                .Select(r => r.Id).FirstOrDefaultAsync();
            _users = await db.Users
                .Where(u => u.IsActive && db.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == consultantRoleId))
                .OrderBy(u => u.FullName)
                .Select(u => new UserOption(u.Id, u.FullName)).ToListAsync();

            // Nguồn: nếu là "Giới thiệu" + có CTV → hiển thị "CTV-<tên>".
            _sourceLabel = Labels.Vi(_lead.Source);
            if (_lead.Source == LeadSource.Referral && _lead.CollaboratorId is Guid ctvId)
            {
                var ctvName = await db.Collaborators.Where(c => c.Id == ctvId).Select(c => c.FullName).FirstOrDefaultAsync();
                if (!string.IsNullOrWhiteSpace(ctvName)) _sourceLabel = $"CTV-{ctvName}";
            }

            _assignedToName = _lead.AssignedTo is null
                ? null
                : _users.FirstOrDefault(u => u.Id == _lead.AssignedTo)?.FullName
                  ?? (await db.Users.Where(u => u.Id == _lead.AssignedTo).Select(u => u.FullName).FirstOrDefaultAsync());

            _convertedCandidateId = await db.Candidates.Where(c => c.LeadId == Id)
                .Select(c => (Guid?)c.Id).FirstOrDefaultAsync();

            _interestedJobOrder = null;
            if (_lead.InterestedJobOrderId is not null)
            {
                var jo = await db.JobOrders.Where(j => j.Id == _lead.InterestedJobOrderId)
                    .Select(j => new { j.Code, j.Country }).FirstOrDefaultAsync();
                if (jo is not null) _interestedJobOrder = $"{jo.Code} — {jo.Country}";
            }
        }
    }

    private async Task OpenEditLead()
    {
        if (!_canUpdateLead) return;
        var parameters = new DialogParameters<LeadDialog> { { x => x.LeadId, Id } };
        var dialog = await DialogService.ShowAsync<LeadDialog>("Sửa thông tin Lead", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Đã cập nhật Lead", Severity.Success);
            await Load();
        }
    }

    private async Task DeleteLead()
    {
        if (_lead is null) return;
        if (!await HasLeadDeleteAccess())
        {
            Snackbar.Add("Bạn không có quyền xóa lead.", Severity.Warning);
            return;
        }

        var message = IsConverted
            ? $"Lead \"{_lead.FullName}\" đã chuyển thành ứng viên. Xóa lead sẽ giữ hồ sơ ứng viên và chỉ bỏ liên kết lead. Bạn có chắc chắn?"
            : $"Xóa lead \"{_lead.FullName}\" cùng lịch sử chăm sóc liên quan. Bạn có chắc chắn?";
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Xóa lead?",
            message,
            yesText: "Xóa",
            cancelText: "Hủy");
        if (confirm != true) return;

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var lead = await db.Leads.FirstOrDefaultAsync(l => l.Id == Id);
            if (lead is null)
            {
                Snackbar.Add("Lead này không còn tồn tại.", Severity.Info);
                Nav.NavigateTo("/leads");
                return;
            }

            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var linkedCandidates = await db.Candidates.Where(c => c.LeadId == Id).ToListAsync();
            foreach (var candidate in linkedCandidates)
                candidate.LeadId = null;

            var activities = await db.LeadActivities.Where(a => a.LeadId == Id).ToListAsync();
            var notifications = await db.Notifications
                .Where(n => n.ReferenceType == "lead" && n.ReferenceId == Id)
                .ToListAsync();
            db.LeadActivities.RemoveRange(activities);
            db.Notifications.RemoveRange(notifications);
            db.AddAudit(actorId, "delete", "leads", lead.Id, new
            {
                lead.Code,
                lead.FullName,
                lead.Phone,
                lead.Status,
                LinkedCandidates = linkedCandidates.Count,
            }, null);
            db.Leads.Remove(lead);
            await db.SaveChangesAsync();

            Snackbar.Add("Đã xóa Lead.", Severity.Success);
            Nav.NavigateTo("/leads");
        }
        finally
        {
            _busy = false;
        }
    }

    private void NotifyConvertedLocked()
        => Snackbar.Add("Lead này đã được chuyển sang ứng viên — không thể thay đổi phân công/lịch hẹn. Chỉ có thể đổi trạng thái (chuyển ngược về Lead).", Severity.Warning);

    private async Task AssignLead()
    {
        if (_lead is null) return;
        if (IsConverted) { NotifyConvertedLocked(); return; }
        if (!await HasLeadUpdateAccess())
        {
            Snackbar.Add("Bạn không có quyền phân công lead.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var lead = await db.Leads.FirstAsync(l => l.Id == Id);
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var old = lead.AssignedTo;
            lead.AssignedTo = _assignTo;
            lead.UpdatedAt = DateTimeOffset.UtcNow;
            var assigneeName = _assignTo is null ? "(bỏ phân công)" : _users.FirstOrDefault(u => u.Id == _assignTo)?.FullName ?? "?";
            db.LeadActivities.Add(new LeadActivity
            {
                LeadId = Id,
                ActivityType = LeadActivityType.Note,
                Content = $"Phân công phụ trách: {assigneeName}",
            });
            db.AddAudit(actorId, "assign", "leads", Id, new { AssignedTo = old }, new { lead.AssignedTo });
            await db.SaveChangesAsync();
            Snackbar.Add("Đã lưu phân công", Severity.Success);
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveAppointment()
    {
        if (_lead is null) return;
        if (IsConverted) { NotifyConvertedLocked(); return; }
        if (!await HasLeadUpdateAccess())
        {
            Snackbar.Add("Bạn không có quyền cập nhật lead.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var lead = await db.Leads.FirstAsync(l => l.Id == Id);
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);

            DateTimeOffset? appt = null;
            if (_appointmentDate is not null)
            {
                var local = _appointmentDate.Value.Date + (_appointmentTime ?? TimeSpan.Zero);
                // Lưu UTC offset 0 theo quy ước Postgres của dự án.
                appt = new DateTimeOffset(local, TimeZoneInfo.Local.GetUtcOffset(local)).ToUniversalTime();
                if (appt < DateTimeOffset.UtcNow)
                {
                    Snackbar.Add("Không thể đặt lịch hẹn ở ngày/giờ đã qua. Vui lòng chọn thời điểm trong tương lai.", Severity.Warning);
                    return;
                }
            }
            lead.AppointmentAt = appt;
            lead.UpdatedAt = DateTimeOffset.UtcNow;
            db.LeadActivities.Add(new LeadActivity
            {
                LeadId = Id,
                ActivityType = LeadActivityType.Appointment,
                Content = appt is null ? "Xóa lịch hẹn tư vấn" : $"Đặt lịch hẹn tư vấn: {appt.Value.ToLocalTime():dd/MM/yyyy HH:mm}",
            });
            await db.SaveChangesAsync();
            Snackbar.Add("Đã lưu lịch hẹn", Severity.Success);
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task UpdateStatus()
    {
        if (_lead is null) return;
        if (!await HasLeadUpdateAccess())
        {
            Snackbar.Add("Bạn không có quyền cập nhật lead.", Severity.Warning);
            return;
        }

        // Lead đã chuyển thành ứng viên → đổi trạng thái = chuyển ngược về Lead.
        if (IsConverted)
        {
            await RevertToLead();
            return;
        }

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var lead = await db.Leads.FirstAsync(l => l.Id == Id);
            var old = lead.Status;
            lead.Status = _newStatus;
            lead.UpdatedAt = DateTimeOffset.UtcNow;
            db.LeadActivities.Add(new LeadActivity
            {
                LeadId = Id,
                ActivityType = LeadActivityType.StatusChange,
                Content = string.IsNullOrWhiteSpace(_statusNote) ? $"Đổi trạng thái: {Labels.Vi(old)} → {Labels.Vi(_newStatus)}" : _statusNote,
                OldStatus = old,
                NewStatus = _newStatus,
            });
            await db.SaveChangesAsync();
            _statusNote = "";
            Snackbar.Add("Đã cập nhật trạng thái", Severity.Success);
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RevertToLead()
    {
        if (_lead is null || _convertedCandidateId is null) return;

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Chuyển ngược về Lead?",
            $"Lead này đã được chuyển thành ứng viên. Đổi trạng thái sẽ XÓA hồ sơ ứng viên và đưa người này trở lại danh sách Lead với trạng thái \"{Labels.Vi(_newStatus)}\". Bạn có chắc chắn?",
            yesText: "Đồng ý, chuyển ngược", cancelText: "Hủy");
        if (confirm != true) return;

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var candidateId = _convertedCandidateId.Value;

            // Chỉ cho chuyển ngược khi ứng viên CHƯA phát sinh dữ liệu — tránh mất dữ liệu ngoài ý muốn.
            var hasData =
                await db.CandidateDocuments.AnyAsync(x => x.CandidateId == candidateId)
                || await db.Payments.AnyAsync(x => x.CandidateId == candidateId)
                || await db.CandidateJobOrders.AnyAsync(x => x.CandidateId == candidateId)
                || await db.Visas.AnyAsync(x => x.CandidateId == candidateId)
                || await db.Flights.AnyAsync(x => x.CandidateId == candidateId)
                || await db.AgentCommissions.AnyAsync(x => x.CandidateId == candidateId);
            if (hasData)
            {
                Snackbar.Add("Không thể chuyển ngược: ứng viên đã phát sinh dữ liệu (giấy tờ/công nợ/đơn hàng/visa/vé/hoa hồng). Hãy xử lý ở trang Ứng viên trước.", Severity.Error);
                return;
            }

            var lead = await db.Leads.FirstAsync(l => l.Id == Id);
            var candidate = await db.Candidates.FirstOrDefaultAsync(c => c.Id == candidateId);
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);

            if (candidate is not null)
            {
                db.AddAudit(actorId, "revert_to_lead", "candidates", candidate.Id,
                    new { candidate.Code, candidate.FullName }, new { reverted = true });
                db.Candidates.Remove(candidate);
            }

            var old = lead.Status;
            lead.Status = _newStatus;
            lead.UpdatedAt = DateTimeOffset.UtcNow;
            db.LeadActivities.Add(new LeadActivity
            {
                LeadId = Id,
                ActivityType = LeadActivityType.StatusChange,
                Content = string.IsNullOrWhiteSpace(_statusNote)
                    ? $"Chuyển ngược ứng viên về Lead: {Labels.Vi(old)} → {Labels.Vi(_newStatus)}"
                    : _statusNote,
                OldStatus = old,
                NewStatus = _newStatus,
            });
            await db.SaveChangesAsync();
            Snackbar.Add("Đã chuyển ngược ứng viên về Lead.", Severity.Success);
            Nav.NavigateTo("/leads");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Convert()
    {
        if (_lead is null) return;
        if (!await HasLeadUpdateAccess() || !await HasPermission("candidates:create"))
        {
            Snackbar.Add("Bạn không có quyền chuyển lead thành ứng viên.", Severity.Warning);
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Chuyển thành ứng viên?",
            $"Tạo hồ sơ ứng viên từ lead \"{_lead.FullName}\" và bắt đầu quy trình 20 bước. Bạn có chắc chắn?",
            yesText: "Đồng ý", cancelText: "Hủy");
        if (confirm != true) return;

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var lead = await db.Leads.FirstAsync(l => l.Id == Id);

            // Chống tạo trùng: nếu lead này đã có hồ sơ ứng viên thì điều hướng tới hồ sơ đó.
            var existingId = await db.Candidates.Where(c => c.LeadId == Id).Select(c => (Guid?)c.Id).FirstOrDefaultAsync();
            if (existingId is not null)
            {
                Snackbar.Add("Lead này đã có hồ sơ ứng viên.", Severity.Info);
                Nav.NavigateTo($"/candidates/{existingId}");
                return;
            }

            var adminId = await db.Users.Select(u => u.Id).FirstOrDefaultAsync();

            var candidate = new Candidate
            {
                Code = $"UV-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1000, 9999)}",
                LeadId = lead.Id,
                FullName = lead.FullName,
                Phone = lead.Phone,
                Province = lead.Province,
                Address = lead.Address,
                Gender = lead.Gender,
                Dob = lead.Dob,
                CccdNumber = lead.Cccd,
                Email = lead.Email,
                Occupation = lead.Occupation,
                EducationLevel = lead.EducationLevel,
                WorkExperience = lead.WorkExperience,
                Languages = lead.Languages,
                AgentId = lead.AgentId,
                CollaboratorId = lead.CollaboratorId, // CTV giới thiệu → tính hoa hồng khi tới bước đặt cọc
                ConsultantId = lead.AssignedTo,        // tư vấn viên theo sát ứng viên
                CreatedBy = adminId,
            };
            db.Candidates.Add(candidate);

            lead.Status = LeadStatus.Converted;
            lead.UpdatedAt = DateTimeOffset.UtcNow;
            db.LeadActivities.Add(new LeadActivity
            {
                LeadId = Id,
                ActivityType = LeadActivityType.StatusChange,
                Content = "Chuyển thành ứng viên",
                NewStatus = LeadStatus.Converted,
            });
            await db.SaveChangesAsync();

            Snackbar.Add("Đã tạo hồ sơ ứng viên", Severity.Success);
            Nav.NavigateTo($"/candidates/{candidate.Id}");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task LoadPermissions()
    {
        _canUpdateLead = await HasLeadUpdateAccess();
        _canDeleteLead = await HasLeadDeleteAccess();
        _canCreateCandidate = await HasPermission("candidates:create");
    }

    private Task<bool> HasLeadUpdateAccess()
        => HasPermission("leads:update", BusinessRoleAccess.CanEditLead);

    private Task<bool> HasLeadDeleteAccess()
        => HasPermission("leads:delete", BusinessRoleAccess.CanDeleteLead);

    private async Task<bool> HasPermission(string permission)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded;
    }

    private async Task<bool> HasPermission(string permission, Func<System.Security.Claims.ClaimsPrincipal, bool> roleCheck)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded && roleCheck(authState.User);
    }

    private async Task<bool> HasAllPermissions(params string[] permissions)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        foreach (var permission in permissions)
        {
            var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
            if (!result.Succeeded) return false;
        }

        return true;
    }

    private static string ActivityLabel(LeadActivityType t) => t switch
    {
        LeadActivityType.Call => "Cuộc gọi",
        LeadActivityType.Note => "Ghi chú",
        LeadActivityType.Email => "Email",
        LeadActivityType.Sms => "SMS",
        LeadActivityType.Zalo => "Zalo",
        LeadActivityType.Appointment => "Hẹn tư vấn",
        LeadActivityType.StatusChange => "Đổi trạng thái",
        _ => t.ToString()
    };

    private int CareThreshold => _lead is null ? 0 : LeadCareRules.ThresholdHours(_lead.Status) ?? 0;

    // Lead chưa chuyển ứng viên + đứng yên quá ngưỡng (LeadCareRules) → số giờ đã đứng yên để hiện banner nhắc.
    private int? CareOverdueHours()
    {
        if (_lead is null || IsConverted) return null;
        var lastChange = _activities
            .Where(a => a.ActivityType == LeadActivityType.StatusChange)
            .Select(a => (DateTimeOffset?)a.CreatedAt)
            .FirstOrDefault() ?? _lead.CreatedAt; // _activities đã sắp mới nhất ở đầu
        return LeadCareRules.TryGetOverdue(_lead.Status, lastChange, _lead.AppointmentAt, DateTimeOffset.UtcNow, out var hours)
            ? hours : null;
    }

    private RenderFragment Field(string label, string? value) =>@<MudItem xs="6">
        <MudText Typo="Typo.caption" Class="mud-text-secondary">@label</MudText>
        <MudText Typo="Typo.body2">@(string.IsNullOrWhiteSpace(value) ? "—" : value)</MudText>
    </MudItem>;
}
