@page "/"
@attribute [Authorize(Policy = "dashboard:read")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AgentScope AgentScope
@inject NavigationManager Nav
@inject IDialogService DialogService

<PageTitle>Tổng quan — POLYMIND</PageTitle>

<PageHeader Eyebrow="POLYMIND OLMS" Title="Tổng quan" Subtitle="Bảng điều khiển hệ thống quản lý xuất khẩu lao động" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 d-block">Bấm vào từng thẻ để xem thống kê sơ lược.</MudText>
    <MudGrid Spacing="2">
        <StatCard Title="Tổng Lead" Value="@_totalLeads.ToString()" Icon="@Icons.Material.Filled.ContactPhone" Color="Color.Info"
                  OnClick="@(() => ShowStat("Tổng Lead", _totalLeads.ToString(), Icons.Material.Filled.ContactPhone, Color.Info, "Tổng số lead đã thu thập trong hệ thống, phân theo trạng thái.", LeadStatusDetails(), "/leads", "Mở danh sách Lead"))" />
        <StatCard Title="Lead mới hôm nay" Value="@_newLeadsToday.ToString()" Icon="@Icons.Material.Filled.FiberNew" Color="Color.Primary"
                  OnClick="@(() => ShowStat("Lead mới hôm nay", _newLeadsToday.ToString(), Icons.Material.Filled.FiberNew, Color.Primary, "Số lead phát sinh trong ngày hôm nay.", NewTodayDetails(), "/leads", "Mở danh sách Lead"))" />
        <StatCard Title="Ứng viên đang xử lý" Value="@_activeCandidates.ToString()" Icon="@Icons.Material.Filled.Groups" Color="Color.Secondary"
                  OnClick="@(() => ShowStat("Ứng viên đang xử lý", _activeCandidates.ToString(), Icons.Material.Filled.Groups, Color.Secondary, "Phân bố ứng viên theo bước hiện tại trong quy trình 20 bước.", StepDetails(), "/candidates", "Mở danh sách Ứng viên"))" />
        <StatCard Title="Đã xuất cảnh" Value="@_departed.ToString()" Icon="@Icons.Material.Filled.FlightTakeoff" Color="Color.Success"
                  OnClick="@(() => ShowStat("Đã xuất cảnh", _departed.ToString(), Icons.Material.Filled.FlightTakeoff, Color.Success, "Số lượt ứng viên đã đến/qua bước Xuất cảnh. Bảng dưới là phễu tuyển dụng.", FunnelDetails()))" />
        <StatCard Title="Tỷ lệ chuyển đổi" Value="@($"{_conversionRate:0.#}%")" Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Warning"
                  OnClick="@(() => ShowStat("Tỷ lệ chuyển đổi", $"{_conversionRate:0.#}%", Icons.Material.Filled.TrendingUp, Color.Warning, "Tỷ lệ lead đã chuyển thành ứng viên.", ConversionDetails()))" />
        <StatCard Title="Đơn hàng đang tuyển" Value="@_openJobOrders.ToString()" Icon="@Icons.Material.Filled.WorkOutline" Color="Color.Dark"
                  OnClick="@(() => ShowStat("Đơn hàng đang tuyển", _openJobOrders.ToString(), Icons.Material.Filled.WorkOutline, Color.Dark, "Phân bố tất cả jobs theo trạng thái.", JobsByStatusDetails(), "/jobs", "Mở danh sách Jobs"))" />
        <StatCard Title="Công nợ phải thu" Value="@($"{_receivables:N0} đ")" Icon="@Icons.Material.Filled.RequestQuote" Color="Color.Warning"
                  OnClick="@(() => ShowStat("Công nợ phải thu", $"{_receivables:N0} đ", Icons.Material.Filled.RequestQuote, Color.Warning, "Tổng các khoản chưa thu (chưa thanh toán/đang chờ/quá hạn).", ReceivablesDetails(), "/finance", "Mở Tài chính"))" />
        <StatCard Title="Khoản thu quá hạn" Value="@_overdueCount.ToString()" Icon="@Icons.Material.Filled.RunningWithErrors" Color="@(_overdueCount > 0 ? Color.Error : Color.Success)"
                  OnClick="@(() => ShowStat("Khoản thu quá hạn", _overdueCount.ToString(), Icons.Material.Filled.RunningWithErrors, _overdueCount > 0 ? Color.Error : Color.Success, "Các khoản thu đã quá hạn thanh toán.", OverdueDetails(), "/finance", "Mở Tài chính"))" />
        <StatCard Title="Sắp xuất cảnh (30 ngày)" Value="@_upcomingDepartures.ToString()" Icon="@Icons.Material.Filled.FlightTakeoff" Color="Color.Secondary"
                  OnClick="@(() => ShowStat("Sắp xuất cảnh (30 ngày)", _upcomingDepartures.ToString(), Icons.Material.Filled.FlightTakeoff, Color.Secondary, "Chuyến bay xuất cảnh dự kiến trong 30 ngày tới, theo điểm đến.", UpcomingByCountryDetails(), "/visa", "Mở Visa & Xuất cảnh"))" />
        <StatCard Title="Doanh thu tháng này" Value="@($"{_monthRevenue:N0} đ")" Icon="@Icons.Material.Filled.Payments" Color="Color.Success"
                  OnClick="@(() => ShowStat("Doanh thu tháng này", $"{_monthRevenue:N0} đ", Icons.Material.Filled.Payments, Color.Success, "Tổng khoản đã thu trong tháng hiện tại. Bảng dưới là doanh thu theo quốc gia (toàn bộ).", RevenueCountryDetails()))" />
        <StatCard Title="Quốc gia doanh thu cao" Value="@_topRevenueCountry" Icon="@Icons.Material.Filled.Public" Color="Color.Info"
                  OnClick="@(() => ShowStat("Quốc gia doanh thu cao", _topRevenueCountry, Icons.Material.Filled.Public, Color.Info, "Xếp hạng doanh thu (đã thu) theo quốc gia.", RevenueCountryDetails()))" />
        <StatCard Title="Tỷ lệ trúng tuyển" Value="@($"{_selectedRate:0.#}%")" Icon="@Icons.Material.Filled.HowToReg" Color="Color.Primary"
                  OnClick="@(() => ShowStat("Tỷ lệ trúng tuyển", $"{_selectedRate:0.#}%", Icons.Material.Filled.HowToReg, Color.Primary, "Tỷ lệ ứng viên đạt từ bước Trúng tuyển trở đi.", FunnelDetails()))" />
        <StatCard Title="Tỷ lệ đậu visa" Value="@($"{_visaApprovedRate:0.#}%")" Icon="@Icons.Material.Filled.AssignmentTurnedIn" Color="Color.Success"
                  OnClick="@(() => ShowStat("Tỷ lệ đậu visa", $"{_visaApprovedRate:0.#}%", Icons.Material.Filled.AssignmentTurnedIn, Color.Success, "Tỷ lệ ứng viên đã đậu visa trở đi.", FunnelDetails()))" />
        <StatCard Title="Tỷ lệ xuất cảnh" Value="@($"{_departureRate:0.#}%")" Icon="@Icons.Material.Filled.FlightTakeoff" Color="Color.Secondary"
                  OnClick="@(() => ShowStat("Tỷ lệ xuất cảnh", $"{_departureRate:0.#}%", Icons.Material.Filled.FlightTakeoff, Color.Secondary, "Tỷ lệ ứng viên đã xuất cảnh trên tổng đang trong quy trình.", FunnelDetails()))" />
    </MudGrid>

    <MudGrid Class="mt-2">
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Lead theo trạng thái</b></MudText>
                @foreach (var kv in _byStatus.OrderByDescending(x => x.Value))
                {
                    <div class="d-flex align-center mb-2">
                        <div style="width:160px"><MudChip T="string" Size="Size.Small" Color="Labels.ColorOf(kv.Key)">@Labels.Vi(kv.Key)</MudChip></div>
                        <MudProgressLinear Color="Labels.ColorOf(kv.Key)" Value="@(_totalLeads == 0 ? 0 : kv.Value * 100.0 / _totalLeads)" Class="flex-grow-1 mx-3" Style="height:10px" Rounded="true" />
                        <b>@kv.Value</b>
                    </div>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Lead theo nguồn</b></MudText>
                @foreach (var kv in _bySource.OrderByDescending(x => x.Value).Take(6))
                {
                    <div class="d-flex justify-space-between align-center mb-2">
                        <span>@Labels.Vi(kv.Key)</span>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@kv.Value</MudChip>
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-2">
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4" Elevation="1" Style="height:100%">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Dashboard doanh thu theo quốc gia</b></MudText>
                @if (_revenueByCountry.Any())
                {
                    @foreach (var row in _revenueByCountry)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-space-between mb-1">
                                <b>@row.Country</b>
                                <span class="mud-text-secondary">@($"{row.Revenue:N0} đ")</span>
                            </div>
                            <MudProgressLinear Color="Color.Success" Value="@(_maxCountryRevenue == 0 ? 0 : (double)(row.Revenue * 100 / _maxCountryRevenue))" Style="height:10px" Rounded="true" />
                        </div>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Chưa có doanh thu gắn với đơn hàng.</MudText>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4" Elevation="1" Style="height:100%">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Top đại lý</b></MudText>
                @if (_topAgents.Any())
                {
                    @foreach (var row in _topAgents)
                    {
                        <div class="d-flex justify-space-between align-center mb-2">
                            <div>
                                <b>@row.AgentName</b>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@row.CandidateCount ứng viên • @row.DepartedCount xuất cảnh</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">@($"{row.TotalCommission:N0} đ")</MudChip>
                        </div>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Chưa có dữ liệu đại lý.</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;
    private int _totalLeads, _newLeadsToday, _activeCandidates, _departed, _openJobOrders;
    private int _overdueCount, _upcomingDepartures;
    private decimal _receivables, _monthRevenue, _maxCountryRevenue;
    private double _conversionRate, _selectedRate, _visaApprovedRate, _departureRate;
    private int _convertedLeads, _funnelBase, _selectedCount, _visaApprovedCount, _departedCount;
    private string _topRevenueCountry = "—";
    private int _openPaymentsCount;
    private decimal _overdueAmount;
    private Dictionary<LeadStatus, int> _byStatus = new();
    private Dictionary<LeadSource, int> _bySource = new();
    private Dictionary<WorkflowStep, int> _byStep = new();
    private Dictionary<JobOrderStatus, int> _jobsByStatus = new();
    private Dictionary<string, int> _upcomingByCountry = new();
    private record RevenueCountryRow(string Country, decimal Revenue);
    private List<RevenueCountryRow> _revenueByCountry = new();
    private record TopAgentRow(string AgentName, int CandidateCount, int DepartedCount, decimal TotalCommission);
    private List<TopAgentRow> _topAgents = new();

    protected override async Task OnInitializedAsync()
    {
        // Đại lý không xem dashboard toàn công ty — chuyển về portal hoa hồng của họ.
        var scope = await AgentScope.GetAsync();
        if (scope.IsPartnerOnly)
        {
            Nav.NavigateTo("/my-commissions", replace: true);
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var financeCandidateIds = await FinanceEligibility.CandidateIdsAsync(db);
        var startOfDay = new DateTimeOffset(DateTime.UtcNow.Date, TimeSpan.Zero);

        _totalLeads = await db.Leads.CountAsync();
        _newLeadsToday = await db.Leads.CountAsync(l => l.CreatedAt >= startOfDay);
        var converted = await db.Leads.CountAsync(l => l.Status == LeadStatus.Converted);
        _convertedLeads = converted;
        _conversionRate = _totalLeads == 0 ? 0 : converted * 100.0 / _totalLeads;

        _activeCandidates = await db.CandidateJobOrders.CountAsync(c => c.Status == CandidateJobOrderStatus.Active);
        _departed = await db.CandidateJobOrders.CountAsync(c => c.CurrentStep >= WorkflowStep.Departure);
        _openJobOrders = await db.JobOrders.CountAsync(j => j.Status == JobOrderStatus.Recruiting);

        _byStatus = await db.Leads.GroupBy(l => l.Status)
            .Select(g => new { g.Key, Count = g.Count() }).ToDictionaryAsync(x => x.Key, x => x.Count);
        _bySource = await db.Leads.GroupBy(l => l.Source)
            .Select(g => new { g.Key, Count = g.Count() }).ToDictionaryAsync(x => x.Key, x => x.Count);

        _byStep = await db.CandidateJobOrders.GroupBy(c => c.CurrentStep)
            .Select(g => new { g.Key, Count = g.Count() }).ToDictionaryAsync(x => x.Key, x => x.Count);
        _jobsByStatus = await db.JobOrders.GroupBy(j => j.Status)
            .Select(g => new { g.Key, Count = g.Count() }).ToDictionaryAsync(x => x.Key, x => x.Count);

        // --- Công nợ + nhắc việc ---
        var todayDate = DateOnly.FromDateTime(DateTime.UtcNow.Date);
        var openPayments = await db.Payments
            .Where(p => financeCandidateIds.Contains(p.CandidateId) && p.Status != PaymentStatus.Paid && p.Status != PaymentStatus.Refunded)
            .Select(p => new { p.Amount, p.DueDate, p.Status }).ToListAsync();
        _receivables = openPayments.Sum(p => p.Amount);
        _openPaymentsCount = openPayments.Count;
        var overduePayments = openPayments.Where(p => p.Status == PaymentStatus.Overdue || (p.DueDate != null && p.DueDate < todayDate)).ToList();
        _overdueCount = overduePayments.Count;
        _overdueAmount = overduePayments.Sum(p => p.Amount);
        var horizon = todayDate.AddDays(30);
        var upcomingFlights = await db.Flights
            .Where(f => f.ActualDepartureAt == null && f.DepartureDate != null
                && f.DepartureDate >= todayDate && f.DepartureDate <= horizon)
            .Select(f => f.DestinationCountry).ToListAsync();
        _upcomingDepartures = upcomingFlights.Count;
        _upcomingByCountry = upcomingFlights
            .GroupBy(c => string.IsNullOrWhiteSpace(c) ? "Chưa rõ" : c!)
            .ToDictionary(g => g.Key, g => g.Count());

        // --- Dashboard doanh thu + phễu tuyển dụng ---
        var firstOfMonth = new DateOnly(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        var paidPayments = await db.Payments.Where(p => financeCandidateIds.Contains(p.CandidateId) && p.Status == PaymentStatus.Paid)
            .Select(p => new { p.CandidateId, p.JobOrderId, p.Amount, p.PaidDate, p.CreatedAt })
            .ToListAsync();
        _monthRevenue = paidPayments
            .Where(p => SameMonth(p.PaidDate ?? DateOnly.FromDateTime(p.CreatedAt.UtcDateTime), firstOfMonth))
            .Sum(p => p.Amount);

        var jobCountries = await db.JobOrders.Select(j => new { j.Id, j.Country }).ToDictionaryAsync(j => j.Id, j => j.Country);
        _revenueByCountry = paidPayments
            .Where(p => p.JobOrderId is not null && jobCountries.ContainsKey(p.JobOrderId.Value))
            .GroupBy(p => jobCountries[p.JobOrderId!.Value])
            .Select(g => new RevenueCountryRow(g.Key, g.Sum(p => p.Amount)))
            .OrderByDescending(x => x.Revenue)
            .Take(5)
            .ToList();
        _maxCountryRevenue = _revenueByCountry.Count == 0 ? 0 : _revenueByCountry.Max(x => x.Revenue);
        _topRevenueCountry = _revenueByCountry.FirstOrDefault()?.Country ?? "—";

        var candidateJobs = await db.CandidateJobOrders.Select(c => new { c.CandidateId, c.JobOrderId, c.CurrentStep }).ToListAsync();
        var visaApprovedPairs = await db.Visas.Where(v => v.Status == VisaStatus.Approved)
            .Select(v => new { v.CandidateId, v.JobOrderId }).ToListAsync();
        var visaApprovedKeys = visaApprovedPairs.Select(v => (v.CandidateId, v.JobOrderId)).ToHashSet();
        var actualDepartures = await db.Flights.Where(f => f.ActualDepartureAt != null)
            .Select(f => new { f.CandidateId, f.JobOrderId }).ToListAsync();
        var departedKeys = actualDepartures.Select(f => (f.CandidateId, f.JobOrderId)).ToHashSet();

        var funnelBase = candidateJobs.Count;
        var selectedCount = candidateJobs.Count(c => c.CurrentStep >= WorkflowStep.Selected);
        var visaApprovedCount = candidateJobs.Count(c =>
            c.CurrentStep >= WorkflowStep.VisaApproved || visaApprovedKeys.Contains((c.CandidateId, c.JobOrderId)));
        var departedCount = candidateJobs.Count(c =>
            c.CurrentStep >= WorkflowStep.Departure || departedKeys.Contains((c.CandidateId, c.JobOrderId)));
        _funnelBase = funnelBase;
        _selectedCount = selectedCount;
        _visaApprovedCount = visaApprovedCount;
        _departedCount = departedCount;
        _selectedRate = Rate(selectedCount, funnelBase);
        _visaApprovedRate = Rate(visaApprovedCount, funnelBase);
        _departureRate = Rate(departedCount, funnelBase);

        var agentNames = await db.Agents.ToDictionaryAsync(a => a.Id, a => a.Name);
        var candidateAgents = await db.Candidates.Where(c => c.AgentId != null)
            .Select(c => new { c.Id, AgentId = c.AgentId!.Value }).ToListAsync();
        var commissions = await db.AgentCommissions
            .Select(c => new { c.AgentId, c.CommissionAmount }).ToListAsync();
        var departedCandidateIds = candidateJobs
            .Where(c => c.CurrentStep >= WorkflowStep.Departure || departedKeys.Contains((c.CandidateId, c.JobOrderId)))
            .Select(c => c.CandidateId)
            .Distinct()
            .ToHashSet();
        _topAgents = candidateAgents
            .GroupBy(c => c.AgentId)
            .Select(g =>
            {
                var candidates = g.Select(c => c.Id).Distinct().ToList();
                return new TopAgentRow(
                    agentNames.GetValueOrDefault(g.Key, "—"),
                    candidates.Count,
                    candidates.Count(departedCandidateIds.Contains),
                    commissions.Where(c => c.AgentId == g.Key).Sum(c => c.CommissionAmount));
            })
            .OrderByDescending(x => x.CandidateCount)
            .ThenByDescending(x => x.TotalCommission)
            .Take(5)
            .ToList();

        _loading = false;
    }

    private static bool SameMonth(DateOnly d, DateOnly month) => d.Year == month.Year && d.Month == month.Month;
    private static double Rate(int count, int total) => total == 0 ? 0 : count * 100.0 / total;

    private async Task ShowStat(string title, string value, string icon, Color color, string note,
        List<StatDetailDialog.Row>? details = null, string? link = null, string linkLabel = "Xem chi tiết")
    {
        var p = new DialogParameters<StatDetailDialog>
        {
            { x => x.Title, title }, { x => x.Value, value }, { x => x.Icon, icon }, { x => x.Color, color },
            { x => x.Note, note }, { x => x.Details, details }, { x => x.LinkHref, link }, { x => x.LinkLabel, linkLabel },
        };
        await DialogService.ShowAsync<StatDetailDialog>(title, p);
    }

    private List<StatDetailDialog.Row> LeadStatusDetails() =>
        _byStatus.OrderByDescending(x => x.Value)
            .Select(x => new StatDetailDialog.Row(Labels.Vi(x.Key), x.Value.ToString())).ToList();

    private List<StatDetailDialog.Row> ConversionDetails() => new()
    {
        new("Tổng lead", _totalLeads.ToString("N0")),
        new("Đã chuyển ứng viên", _convertedLeads.ToString("N0")),
        new("Tỷ lệ", $"{_conversionRate:0.#}%"),
    };

    private List<StatDetailDialog.Row> RevenueCountryDetails() =>
        _revenueByCountry.Select(r => new StatDetailDialog.Row(r.Country, $"{r.Revenue:N0} đ")).ToList();

    private List<StatDetailDialog.Row> FunnelDetails() => new()
    {
        new("Đang trong quy trình", _funnelBase.ToString("N0")),
        new("Trúng tuyển", $"{_selectedCount} ({_selectedRate:0.#}%)"),
        new("Đậu visa", $"{_visaApprovedCount} ({_visaApprovedRate:0.#}%)"),
        new("Xuất cảnh", $"{_departedCount} ({_departureRate:0.#}%)"),
    };

    private List<StatDetailDialog.Row> NewTodayDetails() => new()
    {
        new("Lead mới hôm nay", _newLeadsToday.ToString("N0")),
        new("Tổng lead", _totalLeads.ToString("N0")),
        new("Tỷ trọng", _totalLeads == 0 ? "0%" : $"{_newLeadsToday * 100.0 / _totalLeads:0.#}%"),
    };

    private List<StatDetailDialog.Row> StepDetails() =>
        _byStep.OrderBy(x => (int)x.Key)
            .Select(x => new StatDetailDialog.Row($"{WorkflowSteps.No(x.Key)}. {Labels.Vi(x.Key)}", x.Value.ToString())).ToList();

    private List<StatDetailDialog.Row> JobsByStatusDetails() =>
        _jobsByStatus.OrderByDescending(x => x.Value)
            .Select(x => new StatDetailDialog.Row(Labels.Vi(x.Key), x.Value.ToString())).ToList();

    private List<StatDetailDialog.Row> ReceivablesDetails() => new()
    {
        new("Tổng công nợ phải thu", $"{_receivables:N0} đ"),
        new("Số khoản chưa thu", _openPaymentsCount.ToString("N0")),
        new("Khoản quá hạn", _overdueCount.ToString("N0")),
        new("Tiền quá hạn", $"{_overdueAmount:N0} đ"),
    };

    private List<StatDetailDialog.Row> OverdueDetails() => new()
    {
        new("Số khoản quá hạn", _overdueCount.ToString("N0")),
        new("Tổng tiền quá hạn", $"{_overdueAmount:N0} đ"),
        new("Tổng công nợ phải thu", $"{_receivables:N0} đ"),
    };

    private List<StatDetailDialog.Row> UpcomingByCountryDetails() =>
        _upcomingByCountry.Count == 0
            ? new() { new("Trong 30 ngày tới", _upcomingDepartures.ToString("N0")) }
            : _upcomingByCountry.OrderByDescending(x => x.Value)
                .Select(x => new StatDetailDialog.Row(x.Key, $"{x.Value} chuyến")).ToList();
}
