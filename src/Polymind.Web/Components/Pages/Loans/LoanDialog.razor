@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject AgentScope AgentScope

@* Tạo/sửa hồ sơ hỗ trợ vay của 1 ứng viên (mỗi ứng viên 1 hồ sơ vay). *@
<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12">
                    @if (_candidateLocked)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-1">Ứng viên</MudText>
                        <MudText Typo="Typo.subtitle2" Class="mb-2"><b>@_candidateName</b></MudText>
                    }
                    else
                    {
                        <MudAutocomplete T="CandidateChoice" Value="_selectedCandidate" ValueChanged="OnCandidateChanged"
                                         Label="Chọn ứng viên" SearchFunc="SearchCandidates"
                                         ToStringFunc="@(c => c is null ? string.Empty : $"{c.Name} ({c.Code})")"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" ResetValueOnEmptyText="true"
                                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonSearch" MaxItems="30" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Chỉ hiển thị ứng viên chưa có khoản vay.</MudText>
                    }
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="LoanStatus" @bind-Value="_status" Label="Tình trạng vay" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var s in LoanStatusOptions)
                        {
                            <MudSelectItem T="LoanStatus" Value="@s">@Labels.Vi(s)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="_amount" Label="Số tiền vay (đ)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Format="N0" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="int?" @bind-Value="_termMonths" Label="Thời hạn vay (tháng)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_bankName" Label="Ngân hàng cho vay" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?" @bind-Value="_interestRate" Label="Lãi suất (%/năm)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_disbursedDate" Label="Ngày giải ngân" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_note" Label="Ghi chú" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_saving || _loading" OnClick="SaveAsync">Lưu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Guid CandidateId { get; set; }

    private static readonly LoanStatus[] LoanStatusOptions = { LoanStatus.Borrowing, LoanStatus.Disbursed, LoanStatus.Settled };

    private bool _loading = true;
    private bool _saving;
    private bool _candidateLocked;
    private CandidateChoice? _selectedCandidate;
    private string _candidateName = "—";
    private LoanStatus _status = LoanStatus.Borrowing;
    private decimal? _amount;
    private int? _termMonths;
    private string? _bankName;
    private decimal? _interestRate;
    private DateTime? _disbursedDate;
    private string? _note;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _candidateLocked = CandidateId != Guid.Empty;
        if (!_candidateLocked)
        {
            _loading = false;
            return;
        }

        var candidate = await db.Candidates.Where(c => c.Id == CandidateId)
            .Select(c => new CandidateChoice(c.Id, c.FullName, c.Code))
            .FirstOrDefaultAsync();
        _selectedCandidate = candidate;
        _candidateName = candidate?.Name ?? "—";

        var loan = await db.Loans.OrderByDescending(l => l.CreatedAt).FirstOrDefaultAsync(l => l.CandidateId == CandidateId);
        if (loan is not null)
        {
            _status = loan.Status == LoanStatus.NotBorrowed ? LoanStatus.Borrowing : loan.Status;
            _amount = loan.Amount;
            _termMonths = loan.TermMonths;
            _bankName = loan.BankName;
            _interestRate = loan.InterestRate;
            _disbursedDate = loan.DisbursedDate?.ToDateTime(TimeOnly.MinValue);
            _note = loan.Note;
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var candidateId = _candidateLocked ? CandidateId : _selectedCandidate?.Id ?? Guid.Empty;
            if (candidateId == Guid.Empty)
            {
                Snackbar.Add("Vui lòng chọn ứng viên cần thêm khoản vay.", Severity.Warning);
                return;
            }

            var loan = await db.Loans.OrderByDescending(l => l.CreatedAt).FirstOrDefaultAsync(l => l.CandidateId == candidateId);
            var isNew = loan is null;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var permission = isNew ? "loans:create" : "loans:update";
            var authorization = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
            if (!authorization.Succeeded || !BusinessRoleAccess.CanEditLoan(authState.User))
            {
                Snackbar.Add("Bạn không có quyền lưu hồ sơ vay.", Severity.Warning);
                return;
            }

            if (loan is null)
            {
                loan = new Loan
                {
                    CandidateId = candidateId,
                    Code = $"VAY-{DateTime.UtcNow:yyyyMMdd}-{Random.Shared.Next(1000, 9999)}",
                    CreatedBy = actorId,
                };
                db.Loans.Add(loan);
            }

            loan.Status = _status;
            loan.Amount = _amount;
            loan.TermMonths = _termMonths;
            loan.BankName = string.IsNullOrWhiteSpace(_bankName) ? null : _bankName.Trim();
            loan.InterestRate = _interestRate;
            loan.DisbursedDate = _disbursedDate is null ? null : DateOnly.FromDateTime(_disbursedDate.Value);
            loan.Note = string.IsNullOrWhiteSpace(_note) ? null : _note.Trim();
            loan.UpdatedAt = DateTimeOffset.UtcNow;

            db.AddAudit(actorId, isNew ? "create" : "update", "loans", loan.Id, null, new
            {
                loan.CandidateId,
                loan.Status,
                loan.Amount,
                loan.TermMonths,
                loan.BankName,
            });
            await db.SaveChangesAsync();
            Snackbar.Add("Đã lưu hồ sơ vay.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _saving = false;
        }
    }

    private void OnCandidateChanged(CandidateChoice? candidate)
    {
        _selectedCandidate = candidate;
        CandidateId = candidate?.Id ?? Guid.Empty;
        _candidateName = candidate?.Name ?? "—";
    }

    private async Task<IEnumerable<CandidateChoice>> SearchCandidates(string value, CancellationToken token)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var scope = await AgentScope.GetAsync();
        var query = db.Candidates.AsNoTracking();
        if (scope.IsAgentOnly)
            query = query.Where(c => c.AgentId == scope.AgentId);

        var usedCandidateIds = db.Loans.Select(l => l.CandidateId);
        query = query.Where(c => !usedCandidateIds.Contains(c.Id));

        if (!string.IsNullOrWhiteSpace(value))
        {
            var keyword = value.Trim().ToLower();
            query = query.Where(c => c.FullName.ToLower().Contains(keyword) || c.Code.ToLower().Contains(keyword));
        }

        return await query
            .OrderBy(c => c.FullName)
            .Take(30)
            .Select(c => new CandidateChoice(c.Id, c.FullName, c.Code))
            .ToListAsync(token);
    }

    private record CandidateChoice(Guid Id, string Name, string Code);
}
