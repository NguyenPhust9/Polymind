@page "/visa"
@attribute [Authorize(Policy = "visas:read")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Visa & Xuất cảnh — POLYMIND</PageTitle>

<PageHeader Eyebrow="XUẤT CẢNH" Title="Visa & Xuất cảnh" Subtitle="Theo dõi hồ sơ visa và lịch bay của ứng viên" />

<MudPaper Elevation="1" Class="pa-2">
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="pa-2">
        <MudTabPanel Text="@($"Hồ sơ Visa ({_visas.Count})")">
            <div class="d-flex justify-end mb-3">
                <AuthorizeView Policy="visas:create">
                    <Authorized>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateVisa">
                            Thêm hồ sơ visa
                        </MudButton>
                    </Authorized>
                </AuthorizeView>
            </div>
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudDataGrid T="VisaRow" Items="_visas" Hover="true" Dense="true" Striped="true">
                    <Columns>
                        <PropertyColumn Property="x => x.CandidateName" Title="Ứng viên" />
                        <PropertyColumn Property="x => x.Country" Title="Quốc gia" />
                        <PropertyColumn Property="x => x.VisaType" Title="Loại visa" />
                        <TemplateColumn Title="Trạng thái">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small" Color="Labels.ColorOf(context.Item.Status)">@Labels.Vi(context.Item.Status)</MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Ngày nộp">
                            <CellTemplate>@(context.Item.SubmittedDate?.ToString("dd/MM/yyyy") ?? "—")</CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="" Sortable="false">
                            <CellTemplate>
                                @if (_canUpdateVisa)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditVisa(context.Item.Id))" />
                                }
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent><MudDataGridPager T="VisaRow" /></PagerContent>
                </MudDataGrid>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
                @if (_visas.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary py-4" Align="Align.Center">Chưa có hồ sơ visa.</MudText>
                }
                else
                {
                    @foreach (var v in _visas)
                    {
                        <MudPaper Class="mobile-card pa-3" Elevation="0">
                            <div class="d-flex justify-space-between align-center" style="gap:8px">
                                <div style="min-width:0">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600">@v.CandidateName</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@v.Country • @(string.IsNullOrWhiteSpace(v.VisaType) ? "—" : v.VisaType)</MudText>
                                </div>
                                <MudChip T="string" Size="Size.Small" Color="Labels.ColorOf(v.Status)">@Labels.Vi(v.Status)</MudChip>
                            </div>
                            <div class="d-flex justify-space-between align-center mt-2" style="gap:8px">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Nộp: @(v.SubmittedDate?.ToString("dd/MM/yyyy") ?? "—")</MudText>
                                @if (_canUpdateVisa)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditVisa(v.Id))" />
                                }
                            </div>
                        </MudPaper>
                    }
                }
            </MudHidden>
        </MudTabPanel>

        <MudTabPanel Text="@($"Vé máy bay ({_flights.Count})")">
            <div class="d-flex justify-end mb-3">
                <AuthorizeView Policy="flights:create">
                    <Authorized>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateFlight">
                            Thêm vé máy bay
                        </MudButton>
                    </Authorized>
                </AuthorizeView>
            </div>
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudDataGrid T="FlightRow" Items="_flights" Hover="true" Dense="true" Striped="true">
                    <Columns>
                        <PropertyColumn Property="x => x.CandidateName" Title="Ứng viên" />
                        <PropertyColumn Property="x => x.Airline" Title="Hãng bay" />
                        <PropertyColumn Property="x => x.TicketCode" Title="Mã vé" />
                        <PropertyColumn Property="x => x.Destination" Title="Điểm đến" />
                        <TemplateColumn Title="Giờ bay">
                            <CellTemplate>@context.Item.DepartureText</CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="" Sortable="false">
                            <CellTemplate>
                                @if (_canUpdateFlight)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditFlight(context.Item.Id))" />
                                }
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent><MudDataGridPager T="FlightRow" /></PagerContent>
                </MudDataGrid>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
                @if (_flights.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary py-4" Align="Align.Center">Chưa có vé máy bay.</MudText>
                }
                else
                {
                    @foreach (var f in _flights)
                    {
                        <MudPaper Class="mobile-card pa-3" Elevation="0">
                            <div class="d-flex justify-space-between align-center" style="gap:8px">
                                <div style="min-width:0">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600">@f.CandidateName</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(f.Airline) ? "—" : f.Airline) • @(string.IsNullOrWhiteSpace(f.TicketCode) ? "—" : f.TicketCode)</MudText>
                                </div>
                                @if (_canUpdateFlight)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditFlight(f.Id))" />
                                }
                            </div>
                            <div class="d-flex justify-space-between align-center mt-2" style="gap:8px">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@(string.IsNullOrWhiteSpace(f.Destination) ? "—" : f.Destination)</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@f.DepartureText</MudText>
                            </div>
                        </MudPaper>
                    }
                }
            </MudHidden>
        </MudTabPanel>
    </MudTabs>
</MudPaper>

@code {
    private record VisaRow(Guid Id, string CandidateName, string Country, string? VisaType, VisaStatus Status, DateOnly? SubmittedDate);
    private record FlightRow(Guid Id, string CandidateName, string? Airline, string? TicketCode, string? Destination, string DepartureText);

    private List<VisaRow> _visas = new();
    private List<FlightRow> _flights = new();
    private bool _canUpdateVisa, _canUpdateFlight;

    protected override async Task OnInitializedAsync()
    {
        _canUpdateVisa = await HasPermission("visas:update");
        _canUpdateFlight = await HasPermission("flights:update");
        await Load();
    }

    private async Task Load()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var names = await db.Candidates.ToDictionaryAsync(c => c.Id, c => c.FullName);

        var visas = await db.Visas.OrderByDescending(v => v.CreatedAt).ToListAsync();
        _visas = visas.Select(v => new VisaRow(
            v.Id, names.GetValueOrDefault(v.CandidateId, "—"), v.Country, v.VisaType, v.Status, v.SubmittedDate)).ToList();

        var flights = await db.Flights.OrderByDescending(f => f.CreatedAt).ToListAsync();
        _flights = flights.Select(f => new FlightRow(
            f.Id, names.GetValueOrDefault(f.CandidateId, "—"), f.Airline, f.TicketCode,
            f.DestinationCountry,
            f.DepartureDate is null ? "—" : f.DepartureDate.Value.ToString("dd/MM/yyyy") + (f.DepartureTime is null ? "" : " " + f.DepartureTime.Value.ToString("HH:mm")))).ToList();
    }

    private async Task OpenCreateVisa()
    {
        if (!await HasPermission("visas:create")) { Snackbar.Add("Bạn không có quyền tạo hồ sơ visa.", Severity.Warning); return; }
        var dialog = await DialogService.ShowAsync<VisaDialog>("Thêm hồ sơ visa");
        await HandleResult(dialog, "Đã lưu hồ sơ visa");
    }

    private async Task OpenEditVisa(Guid id)
    {
        var parameters = new DialogParameters<VisaDialog> { { x => x.VisaId, id } };
        var dialog = await DialogService.ShowAsync<VisaDialog>("Sửa hồ sơ visa", parameters);
        await HandleResult(dialog, "Đã cập nhật hồ sơ visa");
    }

    private async Task OpenCreateFlight()
    {
        if (!await HasPermission("flights:create")) { Snackbar.Add("Bạn không có quyền tạo vé máy bay.", Severity.Warning); return; }
        var dialog = await DialogService.ShowAsync<FlightDialog>("Thêm vé máy bay");
        await HandleResult(dialog, "Đã lưu vé máy bay");
    }

    private async Task OpenEditFlight(Guid id)
    {
        var parameters = new DialogParameters<FlightDialog> { { x => x.FlightId, id } };
        var dialog = await DialogService.ShowAsync<FlightDialog>("Sửa vé máy bay", parameters);
        await HandleResult(dialog, "Đã cập nhật vé máy bay");
    }

    private async Task HandleResult(IDialogReference dialog, string successMessage)
    {
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add(successMessage, Severity.Success);
            await Load();
        }
    }

    private async Task<bool> HasPermission(string permission)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded;
    }
}
