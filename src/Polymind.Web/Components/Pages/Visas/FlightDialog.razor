@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudSelect T="Guid?" Value="_selectedCjoId" ValueChanged="OnCjoChanged" Label="Ứng viên – Đơn hàng *"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" Disabled="IsEdit">
                    @foreach (var o in _options)
                    {
                        <MudSelectItem T="Guid?" Value="@o.CjoId">@o.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_m.Airline" Label="Hãng bay" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_m.TicketCode" Label="Mã vé" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_m.DepartureDate" Label="Ngày bay" Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTimePicker @bind-Time="_m.DepartureTime" Label="Giờ bay" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_m.DepartureAirport" Label="Sân bay đi" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_m.DestinationAirport" Label="Sân bay đến" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_m.Notes" Label="Ghi chú" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="_saving">Lưu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Null = tạo mới; có giá trị = sửa vé hiện có.</summary>
    [Parameter] public Guid? FlightId { get; set; }

    private record CjoOption(Guid CjoId, Guid CandidateId, Guid JobOrderId, string Country, string Label);

    private readonly FormModel _m = new();
    private List<CjoOption> _options = new();
    private Guid? _selectedCjoId;
    private bool _saving;
    private bool IsEdit => FlightId is not null;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _options = await db.CandidateJobOrders
            .OrderByDescending(c => c.CreatedAt)
            .Select(c => new CjoOption(
                c.Id, c.CandidateId, c.JobOrderId, c.JobOrder.Country,
                c.Candidate.FullName + " — " + c.JobOrder.Code + " (" + c.JobOrder.Country + ")"))
            .ToListAsync();

        if (FlightId is not null)
        {
            var f = await db.Flights.FirstOrDefaultAsync(x => x.Id == FlightId);
            if (f is not null)
            {
                _m.LoadFrom(f);
                _selectedCjoId = _options.FirstOrDefault(o => o.CandidateId == f.CandidateId && o.JobOrderId == f.JobOrderId)?.CjoId;
            }
        }
    }

    private void OnCjoChanged(Guid? cjoId)
    {
        _selectedCjoId = cjoId;
        var o = _options.FirstOrDefault(x => x.CjoId == cjoId);
        if (o is not null)
        {
            _m.CandidateId = o.CandidateId;
            _m.JobOrderId = o.JobOrderId;
            _m.DestinationCountry = o.Country;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        if (_m.CandidateId == Guid.Empty || _m.JobOrderId == Guid.Empty)
        {
            Snackbar.Add("Vui lòng chọn ứng viên – đơn hàng.", Severity.Warning);
            return;
        }

        var permission = IsEdit ? "flights:update" : "flights:create";
        if (!await HasPermission(permission))
        {
            Snackbar.Add("Bạn không có quyền thực hiện thao tác này.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (IsEdit)
            {
                var f = await db.Flights.FirstOrDefaultAsync(x => x.Id == FlightId);
                if (f is null)
                {
                    Snackbar.Add("Không tìm thấy vé.", Severity.Error);
                    return;
                }
                _m.ApplyTo(f);
                f.UpdatedAt = DateTimeOffset.UtcNow;
            }
            else
            {
                var f = new Flight { AssignedTo = await db.Users.Select(u => u.Id).FirstOrDefaultAsync() };
                _m.ApplyTo(f);
                db.Flights.Add(f);
            }
            await db.SaveChangesAsync();
        }
        finally
        {
            _saving = false;
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task<bool> HasPermission(string permission)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded;
    }

    private sealed class FormModel
    {
        public Guid CandidateId { get; set; }
        public Guid JobOrderId { get; set; }
        public string? Airline { get; set; }
        public string? TicketCode { get; set; }
        public DateTime? DepartureDate { get; set; }
        public TimeSpan? DepartureTime { get; set; }
        public string? DepartureAirport { get; set; }
        public string? DestinationCountry { get; set; }
        public string? DestinationAirport { get; set; }
        public string? Notes { get; set; }

        public void LoadFrom(Flight f)
        {
            CandidateId = f.CandidateId;
            JobOrderId = f.JobOrderId;
            Airline = f.Airline;
            TicketCode = f.TicketCode;
            DepartureDate = f.DepartureDate?.ToDateTime(TimeOnly.MinValue);
            DepartureTime = f.DepartureTime?.ToTimeSpan();
            DepartureAirport = f.DepartureAirport;
            DestinationCountry = f.DestinationCountry;
            DestinationAirport = f.DestinationAirport;
            Notes = f.Notes;
        }

        public void ApplyTo(Flight f)
        {
            f.CandidateId = CandidateId;
            f.JobOrderId = JobOrderId;
            f.Airline = Airline;
            f.TicketCode = TicketCode;
            f.DepartureDate = DepartureDate is null ? null : DateOnly.FromDateTime(DepartureDate.Value);
            f.DepartureTime = DepartureTime is null ? null : TimeOnly.FromTimeSpan(DepartureTime.Value);
            f.DepartureAirport = DepartureAirport;
            f.DestinationCountry = DestinationCountry;
            f.DestinationAirport = DestinationAirport;
            f.Notes = Notes;
        }
    }
}
