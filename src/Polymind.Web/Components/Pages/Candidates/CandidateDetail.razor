    private (Color Color, bool Done, bool Current, bool Pending) StateOf(WorkflowStep step)
    {
        if (_cjo is null) return (Color.Default, false, false, true);
        if (step < _cjo.CurrentStep) return (Color.Success, true, false, false);
        if (step == _cjo.CurrentStep) return (Color.Primary, false, true, false);
        return (Color.Default, false, false, true);
    }

    private async Task AdvanceStep()
    {
        if (_cjo is null || _cjo.CurrentStep >= WorkflowStep.Completed) return;
        // Bước 7.5 không đi qua nút này — phải gắn đơn hàng mới (ReassignJobOrder).
        if (_cjo.CurrentStep == WorkflowStep.ReselectJobOrder) return;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!WorkflowStepAccess.CanAdvance(authState.User, _cjo.CurrentStep))
        {
            Snackbar.Add("Bạn không có quyền cập nhật quy trình ứng viên.", Severity.Warning);
            return;
        }

        // Ràng buộc tình huống theo bước (dấu "/" = lựa chọn theo hồ sơ).
        string? stepNotes = null;
        var stepStatus = WorkflowStepStatus.Completed;
        switch (_cjo.CurrentStep)
        {
            case WorkflowStep.EntranceExam:
                if (string.IsNullOrEmpty(_examMode))
                {
                    Snackbar.Add("Chọn tình huống xét tuyển (Thi tuyển / Phỏng vấn / Xét duyệt hồ sơ) trước.", Severity.Warning);
                    return;
                }
                stepNotes = $"Tình huống: {_examMode} — Đậu";
                break;
            case WorkflowStep.Orientation:
                if (_skipTraining)
                {
                    stepNotes = "Bỏ qua — đơn hàng không yêu cầu học";
                    stepStatus = WorkflowStepStatus.Skipped;
                }
                else
                {
                    var subjects = new List<string>();
                    if (_learnLanguage) subjects.Add("Học tiếng");
                    if (_learnOrientation) subjects.Add("Học định hướng");
                    if (_learnVocational) subjects.Add("Học nghề");
                    if (subjects.Count == 0)
                    {
                        Snackbar.Add("Chọn ít nhất một nội dung học, hoặc bật Bỏ qua nếu đơn hàng không yêu cầu.", Severity.Warning);
                        return;
                    }
                    stepNotes = string.Join(" + ", subjects);
                }
                break;
            case WorkflowStep.FullPayment:
                if (string.IsNullOrEmpty(_paymentMode))
                {
                    Snackbar.Add("Chọn hình thức: Thanh toán hoàn tất hoặc Cam kết trả nợ.", Severity.Warning);
                    return;
                }
                if (_paymentMode == "Cam kết trả nợ" && !_hasLoan)
                {
                    Snackbar.Add("Ứng viên chưa có hồ sơ vay — tạo khoản vay ở thẻ Hỗ trợ vay vốn trước.", Severity.Warning);
                    return;
                }
                stepNotes = _paymentMode;
                break;
            case WorkflowStep.OverseasSupport:
                // Gate B20: hết nghĩa vụ (vay tất toán / không vay) + xác nhận thủ công.
                if (_hasOpenLoan)
                {
                    Snackbar.Add("Khoản vay chưa tất toán — chưa thể hoàn thành quy trình.", Severity.Warning);
                    return;
                }
                var confirm = await DialogService.ShowMessageBoxAsync(
                    "Hoàn thành quy trình?",
                    $"Xác nhận ứng viên \"{_candidate?.FullName}\" đã hết nghĩa vụ (nợ vay tất toán/không vay, không còn hỗ trợ thuế/tái tuyển đang xử lý) và hoàn thành quy trình 20 bước?",
                    yesText: "Xác nhận hoàn thành",
                    cancelText: "Hủy");
                if (confirm != true) return;
                stepNotes = "Xác nhận hết nghĩa vụ — hoàn thành quy trình";
                break;
        }

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var cjo = await db.CandidateJobOrders.FirstAsync(j => j.Id == _cjo.Id);
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var completed = cjo.CurrentStep;
            var next = WorkflowSteps.Next(cjo.CurrentStep);
            var oldStatus = cjo.Status;

            db.WorkflowStepRecords.Add(new WorkflowStepRecord
            {
                CandidateJobOrderId = cjo.Id,
                Step = completed,
                Status = stepStatus,
                AssignedTo = actorId,
                CompletedAt = DateTimeOffset.UtcNow,
                Notes = stepNotes,
                CreatedBy = actorId,
            });
            cjo.CurrentStep = next;
            cjo.UpdatedAt = DateTimeOffset.UtcNow;
            if (next == WorkflowStep.Completed) cjo.Status = CandidateJobOrderStatus.Completed;

            var newCommissions = await EnsureCommissionsAsync(db, cjo, _candidate?.AgentId, actorId);
            db.AddAudit(actorId, "advance_step", "candidate_job_orders", cjo.Id, new
            {
                CurrentStep = completed,
                Status = oldStatus,
            }, new
            {
                CurrentStep = next,
                cjo.Status,
                CompletedStep = completed,
                NewCommissions = newCommissions,
            });
            await db.SaveChangesAsync();

            Snackbar.Add($"Đã chuyển sang bước: {Labels.Vi(next)}", Severity.Success);
            if (newCommissions > 0)
                Snackbar.Add($"Đã phát sinh {newCommissions} mốc hoa hồng cho đại lý.", Severity.Info);
            _examMode = null;
            _failNotes = "";
            _paymentMode = null;
            _skipTraining = _learnLanguage = _learnOrientation = _learnVocational = false;
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>B8 rớt (thi trượt / chủ từ chối / hồ sơ bị loại) → lùi về bước phụ 7.5 "Chọn lại đơn hàng khác".</summary>
    private async Task FailEntranceExam()
    {
        if (_cjo is null || _cjo.CurrentStep != WorkflowStep.EntranceExam) return;
        if (string.IsNullOrEmpty(_examMode))
        {
            Snackbar.Add("Chọn tình huống xét tuyển trước khi đánh rớt.", Severity.Warning);
            return;
        }
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!WorkflowStepAccess.CanAdvance(authState.User, WorkflowStep.EntranceExam))
        {
            Snackbar.Add("Bạn không có quyền cập nhật quy trình ứng viên.", Severity.Warning);
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Đánh rớt bước 8?",
            $"Ứng viên \"{_candidate?.FullName}\" rớt {_examMode} — hồ sơ lùi về bước 7.5 để chọn lại đơn hàng khác (giữ nguyên hồ sơ). Bạn có chắc chắn?",
            yesText: "Đánh rớt",
            cancelText: "Hủy");
        if (confirm != true) return;

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var cjo = await db.CandidateJobOrders.FirstAsync(j => j.Id == _cjo.Id);
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var note = $"Rớt ({_examMode})" + (string.IsNullOrWhiteSpace(_failNotes) ? "" : $": {_failNotes.Trim()}");

            db.WorkflowStepRecords.Add(new WorkflowStepRecord
            {
                CandidateJobOrderId = cjo.Id,
                Step = WorkflowStep.EntranceExam,
                Status = WorkflowStepStatus.Failed,
                AssignedTo = actorId,
                CompletedAt = DateTimeOffset.UtcNow,
                Notes = note,
                CreatedBy = actorId,
            });
            cjo.CurrentStep = WorkflowStep.ReselectJobOrder;
            cjo.UpdatedAt = DateTimeOffset.UtcNow;
            db.AddAudit(actorId, "fail_step", "candidate_job_orders", cjo.Id,
                new { CurrentStep = WorkflowStep.EntranceExam },
                new { cjo.CurrentStep, Note = note });
            await db.SaveChangesAsync();

            Snackbar.Add("Đã lùi hồ sơ về bước 7.5 — chọn lại đơn hàng khác.", Severity.Warning);
            _examMode = null;
            _failNotes = "";
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>B7.5 → B8: bắt buộc gắn đơn hàng MỚI (khác đơn rớt); giữ nguyên hồ sơ và lịch sử bước.</summary>
    private async Task ReassignJobOrder()
    {
        if (_cjo is null || _cjo.CurrentStep != WorkflowStep.ReselectJobOrder || _reassignJobOrderId is null) return;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!WorkflowStepAccess.CanAdvance(authState.User, WorkflowStep.ReselectJobOrder))
        {
            Snackbar.Add("Bạn không có quyền gắn lại đơn hàng cho ứng viên.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var cjo = await db.CandidateJobOrders.FirstAsync(j => j.Id == _cjo.Id);

            // Ràng buộc cứng: phải là đơn hàng KHÁC đơn cũ và còn hạn ứng tuyển.
            if (_reassignJobOrderId.Value == cjo.JobOrderId)
            {
                Snackbar.Add("Phải chọn đơn hàng MỚI (khác đơn hàng đã rớt).", Severity.Warning);
                return;
            }
            var newJob = await db.JobOrders.FirstOrDefaultAsync(j => j.Id == _reassignJobOrderId.Value);
            if (newJob is null) return;
            if (newJob.ApplicationDeadline is DateOnly deadline && deadline < DateOnly.FromDateTime(DateTime.Today))
            {
                Snackbar.Add($"Job {newJob.Code} đã hết hạn ứng tuyển ({deadline:dd/MM/yyyy}).", Severity.Warning);
                return;
            }

            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var oldJobCode = await db.JobOrders.Where(j => j.Id == cjo.JobOrderId).Select(j => j.Code).FirstOrDefaultAsync();

            db.WorkflowStepRecords.Add(new WorkflowStepRecord
            {
                CandidateJobOrderId = cjo.Id,
                Step = WorkflowStep.ReselectJobOrder,
                Status = WorkflowStepStatus.Completed,
                AssignedTo = actorId,
                CompletedAt = DateTimeOffset.UtcNow,
                Notes = $"Đổi từ đơn {oldJobCode} sang {newJob.Code}" + (string.IsNullOrWhiteSpace(_reassignNotes) ? "" : $" — {_reassignNotes.Trim()}"),
                CreatedBy = actorId,
            });
            var oldJobOrderId = cjo.JobOrderId;
            cjo.JobOrderId = newJob.Id;
            cjo.CurrentStep = WorkflowStep.EntranceExam;
            cjo.UpdatedAt = DateTimeOffset.UtcNow;
            db.AddAudit(actorId, "reselect_job_order", "candidate_job_orders", cjo.Id,
                new { JobOrderId = oldJobOrderId, CurrentStep = WorkflowStep.ReselectJobOrder },
                new { cjo.JobOrderId, cjo.CurrentStep });
            await db.SaveChangesAsync();

            Snackbar.Add($"Đã gắn đơn hàng mới {newJob.Code} — hồ sơ sang bước 8.", Severity.Success);
            _reassignJobOrderId = null;
            _reassignNotes = "";
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>B19: thêm 1 ghi chú vào nhật ký tương tác giai đoạn xứ người (record InProgress).</summary>
    private async Task AddOverseasLog()
    {
        if (_cjo is null || string.IsNullOrWhiteSpace(_overseasLogText) || !_canLogOverseas) return;

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var record = new WorkflowStepRecord
            {
                CandidateJobOrderId = _cjo.Id,
                Step = WorkflowStep.OverseasSupport,
                Status = WorkflowStepStatus.InProgress,
                AssignedTo = actorId,
                StartedAt = DateTimeOffset.UtcNow,
                Notes = _overseasLogText.Trim(),
                CreatedBy = actorId,
            };
            db.WorkflowStepRecords.Add(record);
            db.AddAudit(actorId, "overseas_log", "workflow_step_records", record.Id, null, new
            {
                record.CandidateJobOrderId,
                record.Step,
                record.Notes,
            });
            await db.SaveChangesAsync();

            Snackbar.Add("Đã thêm ghi chú tương tác.", Severity.Success);
            _overseasLogText = "";
            await Load();
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnDocumentSelected(InputFileChangeEventArgs args)
    {
        _selectedDocumentFile = args.File;
    }

    private async Task UploadDocument()
    {
        if (_selectedDocumentFile is null)
        {
            Snackbar.Add("Vui lòng chọn file hồ sơ.", Severity.Warning);
            return;
        }
        if (!await HasPermission("candidates:update"))
        {
            Snackbar.Add("Bạn không có quyền upload hồ sơ ứng viên.", Severity.Warning);
            return;
        }

        _uploading = true;
        try
        {
            var uploaded = await DocumentStorage.UploadAsync(Id, _uploadDocType, _selectedDocumentFile);

            await using var db = await DbFactory.CreateDbContextAsync();
            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var document = await db.CandidateDocuments
                .FirstOrDefaultAsync(d => d.CandidateId == Id && d.DocType == _uploadDocType);

            var createdDocument = false;
            if (document is null)
            {
                document = new CandidateDocument
                {
                    CandidateId = Id,
                    DocType = _uploadDocType,
                };
                db.CandidateDocuments.Add(document);
                createdDocument = true;
            }

            var nextVersion = await db.DocumentVersions
                .Where(v => v.DocumentId == document.Id)
                .MaxAsync(v => (int?)v.VersionNumber) ?? 0;

            var version = new DocumentVersion
            {
                DocumentId = document.Id,
                VersionNumber = nextVersion + 1,
                FileUrl = uploaded.ObjectKey,
                FileName = uploaded.FileName,
                FileSize = uploaded.FileSize,
                MimeType = uploaded.ContentType,
                UploadedBy = actorId,
                Notes = string.IsNullOrWhiteSpace(_documentNotes) ? null : _documentNotes.Trim(),
            };
            db.DocumentVersions.Add(version);
            document.CurrentVersionId = version.Id;
            document.UpdatedAt = DateTimeOffset.UtcNow;
            db.AddAudit(actorId, createdDocument ? "create" : "upload_version", "candidate_documents", document.Id, null, new
            {
                document.CandidateId,
                document.DocType,
                document.CurrentVersionId,
                VersionId = version.Id,
                version.VersionNumber,
                ObjectKey = version.FileUrl,
                version.FileName,
                version.FileSize,
                version.MimeType,
            });

            await db.SaveChangesAsync();
            Snackbar.Add("Đã upload hồ sơ lên MinIO.", Severity.Success);
            _selectedDocumentFile = null;
            _documentNotes = "";
            await Load();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Không upload được hồ sơ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task DownloadDocument(Guid versionId)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var version = await db.DocumentVersions.FirstOrDefaultAsync(v => v.Id == versionId);
            if (version is null)
            {
                Snackbar.Add("Không tìm thấy phiên bản hồ sơ.", Severity.Warning);
                return;
            }

            var url = await DocumentStorage.GetDownloadUrlAsync(version.FileUrl);
            Nav.NavigateTo(url, forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Không tạo được link tải hồ sơ: {ex.Message}", Severity.Error);
        }
    }

    private void ToggleHistory(Guid documentId)
        => _expandedDocId = _expandedDocId == documentId ? null : documentId;

    private async Task RestoreVersion(Guid documentId, Guid versionId)
    {
        if (!await HasPermission("candidates:update"))
        {
            Snackbar.Add("Bạn không có quyền khôi phục hồ sơ.", Severity.Warning);
            return;
        }
        await using var db = await DbFactory.CreateDbContextAsync();
        var document = await db.CandidateDocuments.FirstOrDefaultAsync(d => d.Id == documentId && d.CandidateId == Id);
        if (document is null) return;
        if (document.CurrentVersionId == versionId) return;

        var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
        var oldVersionId = document.CurrentVersionId;
        document.CurrentVersionId = versionId;
        document.UpdatedAt = DateTimeOffset.UtcNow;
        db.AddAudit(actorId, "restore_version", "candidate_documents", document.Id,
            new { CurrentVersionId = oldVersionId }, new { document.CurrentVersionId });
        await db.SaveChangesAsync();
        Snackbar.Add("Đã đặt phiên bản này làm hiện hành.", Severity.Success);
        await Load();
    }

    // Mốc hoa hồng ↔ bước workflow tương ứng (mục 8.3).
    private static readonly (CommissionMilestone Milestone, WorkflowStep Step)[] CommissionMilestones =
    {
        (CommissionMilestone.Deposit, WorkflowStep.Deposit),
        (CommissionMilestone.Selected, WorkflowStep.Selected),
        (CommissionMilestone.Departure, WorkflowStep.Departure),
    };

    /// <summary>Tự sinh hoa hồng cho các mốc đã đạt (nếu ứng viên có đại lý và có cấu hình). Idempotent.</summary>
    private static async Task<int> EnsureCommissionsAsync(ApplicationDbContext db, CandidateJobOrder cjo, Guid? agentId, Guid actorId)
    {
        if (agentId is null) return 0;
        var jo = await db.JobOrders.FirstOrDefaultAsync(j => j.Id == cjo.JobOrderId);
        if (jo is null) return 0;
        var baseAmount = jo.CostAmount ?? 0m;
        var configs = await db.AgentCommissionConfigs.Where(c => c.AgentId == agentId.Value).ToListAsync();

        var created = 0;
        foreach (var (milestone, step) in CommissionMilestones)
        {
            if ((int)cjo.CurrentStep < (int)step) continue;

            // Không lọc theo JobOrderId: ứng viên đổi đơn ở bước 7.5 không được phát sinh lại
            // mốc hoa hồng đã hưởng (đặt cọc/trúng tuyển chỉ tính 1 lần cho mỗi ứng viên).
            var exists = await db.AgentCommissions.AnyAsync(c =>
                c.AgentId == agentId.Value && c.CandidateId == cjo.CandidateId &&
                c.Milestone == milestone);
            if (exists) continue;

            // Ưu tiên cấu hình theo đúng đơn hàng / quốc gia, rồi tới cấu hình chung.
            var cfg = configs.Where(c => c.Milestone == milestone)
                .OrderByDescending(c => c.JobOrderId == cjo.JobOrderId)
                .ThenByDescending(c => c.Country == jo.Country)
                .FirstOrDefault();
            if (cfg is null) continue;

            var amount = cfg.Percentage.HasValue
                ? baseAmount * cfg.Percentage.Value / 100m
                : (cfg.FixedAmount ?? 0m);

            var commission = new AgentCommission
            {
                AgentId = agentId.Value,
                CandidateId = cjo.CandidateId,
                JobOrderId = cjo.JobOrderId,
                ConfigId = cfg.Id,
                Milestone = milestone,
                BaseAmount = baseAmount,
                CommissionAmount = amount,
                Status = CommissionStatus.Pending,
            };
            db.AgentCommissions.Add(commission);
            db.AddAudit(actorId, "create", "agent_commissions", commission.Id, null, new
            {
                commission.AgentId,
                commission.CandidateId,
                commission.JobOrderId,
                commission.ConfigId,
                commission.Milestone,
                commission.BaseAmount,
                commission.CommissionAmount,
                commission.Status,
            });
            created++;
        }
        return created;
    }

    private async Task<bool> HasPermission(string permission)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded;
    }

    private RenderFragment Field(string label, string? value) =>@<MudItem xs="6">
        <MudText Typo="Typo.caption" Class="mud-text-secondary">@label</MudText>
        <MudText Typo="Typo.body2">@(string.IsNullOrWhiteSpace(value) ? "—" : value)</MudText>
    </MudItem>;

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
            return $"{bytes / 1024d / 1024d:N1} MB";
        if (bytes >= 1024)
            return $"{bytes / 1024d:N1} KB";
        return $"{bytes:N0} B";
    }
