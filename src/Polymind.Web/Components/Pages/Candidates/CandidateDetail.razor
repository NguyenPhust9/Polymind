    private async Task DeleteCandidate()
    {
        if (_candidate is null) return;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!await HasPermission("candidates:delete") || !BusinessRoleAccess.CanDeleteCandidate(authState.User))
        {
            Snackbar.Add("Bạn không có quyền xóa ứng viên.", Severity.Warning);
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Xóa ứng viên?",
            $"Xóa hồ sơ ứng viên \"{_candidate.FullName}\" và toàn bộ dữ liệu nghiệp vụ đi kèm như hồ sơ, tiến trình, công nợ, vay vốn, visa/vé và hoa hồng. Bạn có chắc chắn?",
            yesText: "Xóa",
            cancelText: "Hủy");
        if (confirm != true) return;

        _busy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var candidate = await db.Candidates.FirstOrDefaultAsync(c => c.Id == Id);
            if (candidate is null)
            {
                Snackbar.Add("Ứng viên này không còn tồn tại.", Severity.Info);
                Nav.NavigateTo("/candidates");
                return;
            }

            var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
            var cjoIds = await db.CandidateJobOrders.Where(c => c.CandidateId == Id).Select(c => c.Id).ToListAsync();
            var documentIds = await db.CandidateDocuments.Where(d => d.CandidateId == Id).Select(d => d.Id).ToListAsync();
            var payments = await db.Payments.Where(p => p.CandidateId == Id)
                .Select(p => new { p.Id, p.ReceiptId })
                .ToListAsync();
            var paymentIds = payments.Select(p => p.Id).ToList();
            var paymentReceiptIds = payments.Where(p => p.ReceiptId is not null).Select(p => p.ReceiptId!.Value).ToList();
            var commissionReceiptIds = await db.AgentCommissions
                .Where(c => c.CandidateId == Id && c.ReceiptId != null)
                .Select(c => c.ReceiptId!.Value)
                .ToListAsync();

            var versions = await db.DocumentVersions.Where(v => documentIds.Contains(v.DocumentId)).ToListAsync();
            var documents = await db.CandidateDocuments.Where(d => d.CandidateId == Id).ToListAsync();
            var workflowRecords = await db.WorkflowStepRecords.Where(r => cjoIds.Contains(r.CandidateJobOrderId)).ToListAsync();
            var assignments = await db.CandidateJobOrders.Where(c => c.CandidateId == Id).ToListAsync();
            var loans = await db.Loans.Where(l => l.CandidateId == Id).ToListAsync();
            var paymentRows = await db.Payments.Where(p => p.CandidateId == Id).ToListAsync();
            var receipts = await db.Receipts
                .Where(r => r.CandidateId == Id
                    || (r.PaymentId != null && paymentIds.Contains(r.PaymentId.Value))
                    || paymentReceiptIds.Contains(r.Id)
                    || commissionReceiptIds.Contains(r.Id))
                .ToListAsync();
            var visas = await db.Visas.Where(v => v.CandidateId == Id).ToListAsync();
            var flights = await db.Flights.Where(f => f.CandidateId == Id).ToListAsync();
            var commissions = await db.AgentCommissions.Where(c => c.CandidateId == Id).ToListAsync();
            var notifications = await db.Notifications
                .Where(n => n.ReferenceType == "candidate" && n.ReferenceId == Id)
                .ToListAsync();

            db.DocumentVersions.RemoveRange(versions);
            db.CandidateDocuments.RemoveRange(documents);
            db.WorkflowStepRecords.RemoveRange(workflowRecords);
            db.CandidateJobOrders.RemoveRange(assignments);
            db.Loans.RemoveRange(loans);
            db.Receipts.RemoveRange(receipts);
            db.Payments.RemoveRange(paymentRows);
            db.Visas.RemoveRange(visas);
            db.Flights.RemoveRange(flights);
            db.AgentCommissions.RemoveRange(commissions);
            db.Notifications.RemoveRange(notifications);

            if (candidate.LeadId is Guid leadId)
            {
                var lead = await db.Leads.FirstOrDefaultAsync(l => l.Id == leadId);
                if (lead is not null)
                {
                    lead.Status = LeadStatus.New;
                    lead.UpdatedAt = DateTimeOffset.UtcNow;
                    db.LeadActivities.Add(new LeadActivity
                    {
                        LeadId = lead.Id,
                        ActivityType = LeadActivityType.StatusChange,
                        Content = "Xóa hồ sơ ứng viên liên kết; đưa lead về trạng thái Lead mới",
                        NewStatus = LeadStatus.New,
                    });
                }
            }

            db.AddAudit(actorId, "delete", "candidates", candidate.Id, new
            {
                candidate.Code,
                candidate.FullName,
                candidate.Phone,
                Documents = documents.Count,
                Payments = paymentRows.Count,
                Loans = loans.Count,
                JobOrders = assignments.Count,
            }, null);
            db.Candidates.Remove(candidate);
            await db.SaveChangesAsync();

            Snackbar.Add("Đã xóa hồ sơ ứng viên.", Severity.Success);
            Nav.NavigateTo("/candidates");
        }
        finally
        {
            _busy = false;
        }
    }

