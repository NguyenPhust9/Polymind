@page "/candidates/{Id:guid}"
@attribute [Authorize(Policy = "candidates:read")]
@using Polymind.Web.Components.Pages.Loans
@using Polymind.Web.Components.Pages.Ai
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDocumentStorage DocumentStorage
@inject AgentScope AgentScope

<PageTitle>Chi tiết Ứng viên — POLYMIND</PageTitle>

@if (_accessDenied)
{
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Class="mb-3" OnClick="@(() => Nav.NavigateTo("/candidates"))">Quay lại</MudButton>
    <MudAlert Severity="Severity.Error">Bạn không có quyền xem ứng viên này (chỉ xem được ứng viên do mình giới thiệu).</MudAlert>
}
else if (_candidate is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div class="d-flex justify-space-between align-center mb-3">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/candidates"))">Quay lại</MudButton>
        <div class="d-flex flex-wrap" style="gap:8px">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="OpenAiAnalysis">Phân tích AI</MudButton>
            @if (_canEditCandidateProfile)
            {
                <MudButton Class="entity-action-button" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEdit">Sửa thông tin</MudButton>
            }
            @if (_canDeleteCandidate)
            {
                <MudButton Class="entity-action-button" Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteCandidate" Disabled="_busy">
                    Xóa
                </MudButton>
            }
        </div>
    </div>

    @* ===== Card nổi bật: Người phụ trách ứng viên (TVV + CTV) — bấm để xem chi tiết ===== *@
    <MudPaper Class="pa-4 mb-4 people-card" Elevation="3">
        <div class="d-flex align-center mb-3" style="gap:8px">
            <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Color="Color.Secondary" />
            <MudText Typo="Typo.subtitle1"><b>Người phụ trách ứng viên</b></MudText>
        </div>
        <MudGrid>
            <MudItem xs="12" sm="6">
                @if (_consultantId is not null)
                {
                    <div class="person-tile" @onclick="@(() => ShowConsultant(_consultantId.Value))">
                        <MudAvatar Color="Color.Secondary" Size="Size.Large">@Initials(_consultantName)</MudAvatar>
                        <div style="min-width:0">
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined" Class="mb-1">Tư vấn viên</MudChip>
                            <MudText Typo="Typo.h6" Class="person-name"><b>@_consultantName</b></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Bấm để xem thông tin liên lạc</MudText>
                        </div>
                    </div>
                }
                else
                {
                    <div class="person-tile person-empty">
                        <MudAvatar Color="Color.Default" Size="Size.Large"><MudIcon Icon="@Icons.Material.Filled.PersonOff" /></MudAvatar>
                        <div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined" Class="mb-1">Tư vấn viên</MudChip>
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">Chưa gắn tư vấn viên</MudText>
                        </div>
                    </div>
                }
            </MudItem>
            <MudItem xs="12" sm="6">
                @if (_collaboratorId is not null)
                {
                    <div class="person-tile" @onclick="@(() => ShowCollaborator(_collaboratorId.Value))">
                        <MudAvatar Color="Color.Primary" Size="Size.Large">@Initials(_collaboratorName)</MudAvatar>
                        <div style="min-width:0">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="mb-1">Cộng tác viên (nguồn giới thiệu)</MudChip>
                            <MudText Typo="Typo.h6" Class="person-name"><b>@_collaboratorName</b></MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Bấm để xem thông tin liên lạc</MudText>
                        </div>
                    </div>
                }
                else
                {
                    <div class="person-tile person-empty">
                        <MudAvatar Color="Color.Default" Size="Size.Large"><MudIcon Icon="@Icons.Material.Filled.PersonOff" /></MudAvatar>
                        <div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="mb-1">Cộng tác viên (nguồn giới thiệu)</MudChip>
                            <MudText Typo="Typo.body1" Class="mud-text-secondary">Không qua cộng tác viên</MudText>
                        </div>
                    </div>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <div class="d-flex align-center mb-3">
                    <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-3">@_candidate.FullName[..1]</MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6"><b>@_candidate.FullName</b></MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@_candidate.Code</MudText>
                    </div>
                </div>
                <MudDivider Class="mb-3" />

                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Thông tin cá nhân</b></MudText>
                <MudGrid>
                    @Field("Số điện thoại", _candidate.Phone)
                    @Field("Giới tính", _candidate.Gender is null ? null : Labels.Vi(_candidate.Gender.Value))
                    @Field("Ngày sinh", _candidate.Dob?.ToString("dd/MM/yyyy"))
                    @Field("Hôn nhân", _candidate.MaritalStatus is null ? null : Labels.Vi(_candidate.MaritalStatus.Value))
                    @Field("Tỉnh/Thành", _candidate.Province)
                    @Field("Đơn hàng", _country)
                </MudGrid>
                @if (!string.IsNullOrWhiteSpace(_candidate.Address))
                {
                    <MudText Typo="Typo.body2" Class="mt-2"><b>Địa chỉ:</b> @_candidate.Address</MudText>
                }

                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Giấy tờ</b></MudText>
                <MudGrid>
                    @Field("Số CCCD", _candidate.CccdNumber)
                    @Field("Ngày cấp", _candidate.CccdIssueDate?.ToString("dd/MM/yyyy"))
                    @Field("Nơi cấp", _candidate.CccdIssuePlace)
                    @Field("Số hộ chiếu", _candidate.PassportNumber)
                    @Field("HC hết hạn", _candidate.PassportExpiry?.ToString("dd/MM/yyyy"))
                </MudGrid>

                @if (HasEmergencyInfo)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Liên hệ khẩn cấp</b></MudText>
                    <MudGrid>
                        @Field("Người liên hệ", _candidate.EmergencyContactName)
                        @Field("SĐT", _candidate.EmergencyContactPhone)
                        @Field("Quan hệ", _candidate.EmergencyContactRelation)
                    </MudGrid>
                }

                @if (HasGuardianInfo)
                {
                    <MudDivider Class="my-3" />
                    <div class="d-flex align-center mb-2" style="gap:6px">
                        <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2"><b>Cha/Mẹ/Người bảo hộ</b></MudText>
                    </div>
                    <MudGrid>
                        @Field("Họ tên", _candidate.GuardianName)
                        @Field("Quan hệ", _candidate.GuardianRelation)
                        @Field("SĐT", _candidate.GuardianPhone)
                        @Field("CCCD", _candidate.GuardianCccd)
                        @Field("Nghề nghiệp", _candidate.GuardianOccupation)
                    </MudGrid>
                    @if (!string.IsNullOrWhiteSpace(_candidate.GuardianAddress))
                    {
                        <MudText Typo="Typo.body2" Class="mt-2"><b>Địa chỉ:</b> @_candidate.GuardianAddress</MudText>
                    }
                }

                @if (HasBankInfo)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Ngân hàng</b></MudText>
                    <MudGrid>
                        @Field("Số TK", _candidate.BankAccountNumber)
                        @Field("Ngân hàng", _candidate.BankName)
                        @Field("Chủ TK", _candidate.BankAccountName)
                    </MudGrid>
                }

                @* Thông tin nhạy cảm — chỉ super_admin được xem *@
                <AuthorizeView Roles="super_admin">
                    <Authorized>
                        <MudDivider Class="my-3" />
                        <div class="d-flex align-center mb-2" style="gap:6px">
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle2"><b>Hồ sơ & nguyện vọng (chỉ super admin)</b></MudText>
                        </div>
                        <MudGrid>
                            @Field("Email", _candidate.Email)
                            @Field("Nghề nghiệp", _candidate.Occupation)
                            @Field("Trình độ học vấn", _candidate.EducationLevel)
                            @Field("Kinh nghiệm làm việc", _candidate.WorkExperience)
                            @Field("Ngoại ngữ", _candidate.Languages)
                        </MudGrid>
                    </Authorized>
                </AuthorizeView>
            </MudPaper>

            @if (_cjo is not null && _cjo.CurrentStep >= WorkflowStep.Completed)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">Ứng viên đã hoàn thành toàn bộ quy trình 20 bước 🎉</MudAlert>
            }
            else if (_cjo is not null)
            {
                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-1"><b>Bước hiện tại</b></MudText>
                    <MudChip T="string" Color="@(_cjo.CurrentStep == WorkflowStep.ReselectJobOrder ? Color.Warning : Color.Primary)" Class="mb-3">
                        @($"{WorkflowSteps.No(_cjo.CurrentStep)}. {Labels.Vi(_cjo.CurrentStep)}")
                    </MudChip>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">Phụ trách: @_workflowOwnerLabel</MudText>
                    @if (!_canAdvanceWorkflow)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            Tài khoản này chỉ được xem tiến trình ở bước hiện tại.
                        </MudAlert>
                    }
                    else if (_cjo.CurrentStep == WorkflowStep.EntranceExam)
                    {
                        @* B8: chọn 1 trong 3 tình huống theo đơn hàng; đậu → B9, rớt → lùi về 7.5 *@
                        <MudText Typo="Typo.body2" Class="mb-1"><b>Tình huống xét tuyển</b> (chọn 1 theo đơn hàng)</MudText>
                        <MudRadioGroup T="string" @bind-Value="_examMode">
                            <MudRadio T="string" Value="@("Thi tuyển")" Dense="true">Thi tuyển (đậu/rớt theo bằng cấp, chứng chỉ)</MudRadio>
                            <MudRadio T="string" Value="@("Phỏng vấn")" Dense="true">Phỏng vấn (đậu/rớt do chủ sử dụng)</MudRadio>
                            <MudRadio T="string" Value="@("Xét duyệt hồ sơ")" Dense="true">Xét duyệt hồ sơ (chủ tự duyệt, không phỏng vấn)</MudRadio>
                        </MudRadioGroup>
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-2"
                                   StartIcon="@Icons.Material.Filled.ThumbUp" OnClick="AdvanceStep"
                                   Disabled="@(_busy || string.IsNullOrEmpty(_examMode))">
                            Đậu — chuyển bước Trúng tuyển
                        </MudButton>
                        <MudDivider Class="my-3" />
                        <MudTextField @bind-Value="_failNotes" Label="Lý do rớt / từ chối (nếu có)" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2" />
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.ThumbDown" OnClick="FailEntranceExam"
                                   Disabled="@(_busy || string.IsNullOrEmpty(_examMode))">
                            Rớt / Chủ từ chối — về bước 7.5 chọn lại đơn khác
                        </MudButton>
                    }
                    else if (_cjo.CurrentStep == WorkflowStep.ReselectJobOrder)
                    {
                        @* B7.5: bắt buộc gắn đơn hàng MỚI mới được sang B8 (giữ nguyên hồ sơ) *@
                        @if (!string.IsNullOrWhiteSpace(_lastFailNote))
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">@_lastFailNote</MudAlert>
                        }
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                            Ứng viên rớt bước 8 — phải gắn <b>đơn hàng mới</b> (khác đơn cũ) mới được chuyển sang bước 8. Hồ sơ ứng viên được giữ nguyên.
                        </MudAlert>
                        @if (_reassignJobOrders.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">Chưa có đơn hàng khác còn hạn để gắn.</MudAlert>
                        }
                        else
                        {
                            <MudSelect T="Guid?" @bind-Value="_reassignJobOrderId" Label="Đơn hàng mới" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                                @foreach (var j in _reassignJobOrders)
                                {
                                    <MudSelectItem T="Guid?" Value="@j.Id">@j.Code — @j.Country (@j.CompanyName)</MudSelectItem>
                                }
                            </MudSelect>
                            <MudTextField @bind-Value="_reassignNotes" Label="Ghi chú" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2" />
                            <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Link" OnClick="ReassignJobOrder"
                                       Disabled="@(_busy || _reassignJobOrderId is null)">
                                Gắn đơn hàng mới & sang bước 8
                            </MudButton>
                        }
                    }
                    else if (_cjo.CurrentStep == WorkflowStep.Orientation)
                    {
                        @* B10: chọn được NHIỀU nội dung học, hoặc bỏ qua ("nếu cần") *@
                        <MudText Typo="Typo.body2" Class="mb-1"><b>Nội dung đào tạo</b> (chọn nhiều theo yêu cầu đơn hàng)</MudText>
                        <MudCheckBox T="bool" @bind-Value="_learnLanguage" Dense="true" Disabled="_skipTraining" Label="Học tiếng" />
                        <MudCheckBox T="bool" @bind-Value="_learnOrientation" Dense="true" Disabled="_skipTraining" Label="Học định hướng" />
                        <MudCheckBox T="bool" @bind-Value="_learnVocational" Dense="true" Disabled="_skipTraining" Label="Học nghề" />
                        <MudSwitch T="bool" @bind-Value="_skipTraining" Color="Color.Warning" Label="Bỏ qua — đơn hàng không yêu cầu học" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-2"
                                   StartIcon="@Icons.Material.Filled.ArrowForward" OnClick="AdvanceStep"
                                   Disabled="@(_busy || (!_skipTraining && !_learnLanguage && !_learnOrientation && !_learnVocational))">
                            @(_skipTraining ? "Bỏ qua & chuyển bước tiếp theo" : "Hoàn thành & chuyển bước tiếp theo")
                        </MudButton>
                    }
                    else if (_cjo.CurrentStep == WorkflowStep.FullPayment)
                    {
                        @* B15: chọn 1 trong 2 — thanh toán hoàn tất hoặc cam kết trả nợ (liên kết module vay) *@
                        <MudText Typo="Typo.body2" Class="mb-1"><b>Hình thức hoàn tất tài chính</b> (chọn 1)</MudText>
                        <MudRadioGroup T="string" @bind-Value="_paymentMode">
                            <MudRadio T="string" Value="@("Thanh toán hoàn tất")" Dense="true">Thanh toán hoàn tất</MudRadio>
                            <MudRadio T="string" Value="@("Cam kết trả nợ")" Dense="true">Cam kết trả nợ (có vay vốn)</MudRadio>
                        </MudRadioGroup>
                        @if (_paymentMode == "Cam kết trả nợ" && !_hasLoan)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="my-2">
                                Ứng viên chưa có hồ sơ vay — tạo khoản vay ở thẻ <b>Hỗ trợ vay vốn</b> bên dưới trước khi chuyển bước.
                            </MudAlert>
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-2"
                                   StartIcon="@Icons.Material.Filled.ArrowForward" OnClick="AdvanceStep"
                                   Disabled="@(_busy || string.IsNullOrEmpty(_paymentMode) || (_paymentMode == "Cam kết trả nợ" && !_hasLoan))">
                            Hoàn thành & chuyển bước tiếp theo
                        </MudButton>
                    }
                    else if (_cjo.CurrentStep == WorkflowStep.OverseasSupport)
                    {
                        @* B19 → B20: chỉ khi hết nghĩa vụ (vay đã tất toán / không vay), xác nhận thủ công *@
                        @if (_hasOpenLoan)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                                Khoản vay của ứng viên chưa <b>tất toán</b> (đang: @Labels.Vi(_loanStatus)) — chưa thể hoàn thành quy trình.
                                Khi trả xong nợ, cập nhật khoản vay sang "Đã tất toán" ở thẻ Hỗ trợ vay vốn.
                            </MudAlert>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                                Chỉ xác nhận khi ứng viên không còn nghĩa vụ mở: nợ vay đã tất toán (hoặc không vay), không còn hỗ trợ lấy lại thuế / tái tuyển việc đang xử lý.
                            </MudAlert>
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Verified" OnClick="AdvanceStep" Disabled="@(_busy || _hasOpenLoan)">
                            Xác nhận hoàn thành quy trình (bước 20)
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.ArrowForward" OnClick="AdvanceStep" Disabled="_busy">
                            Hoàn thành & chuyển bước tiếp theo
                        </MudButton>
                    }
                </MudPaper>
            }

            @if (_cjo is null && _canAssignJobOrder)
            {
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-1"><b>Gắn vào đơn hàng</b></MudText>
                    <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">Chọn đơn hàng để bắt đầu quy trình 20 bước cho ứng viên.</MudText>
                    @if (_jobOrders.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">Chưa có đơn hàng nào để gắn.</MudAlert>
                    }
                    else
                    {
                        <MudSelect T="Guid?" @bind-Value="_selectedJobOrderId" Label="Đơn hàng" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                            @foreach (var j in _jobOrders)
                            {
                                <MudSelectItem T="Guid?" Value="@j.Id">@j.Code — @j.Country (@j.CompanyName)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudTextField @bind-Value="_assignNotes" Label="Ghi chú" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Link" OnClick="AssignJobOrder" Disabled="_busy || _selectedJobOrderId is null">
                            Gắn vào đơn hàng
                        </MudButton>
                    }
                </MudPaper>
            }

            @if (CanShowCandidateDebt)
            {
                <MudPaper Class="pa-4 mt-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Công nợ ứng viên</b></MudText>
                    <MudGrid Class="mb-2">
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Phải thu</MudText>
                            <MudText Typo="Typo.body1"><b>@($"{_paymentTotal:N0} đ")</b></MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Đã thu</MudText>
                            <MudText Typo="Typo.body1" Color="Color.Success"><b>@($"{_paymentPaid:N0} đ")</b></MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Còn nợ</MudText>
                            <MudText Typo="Typo.body1" Color="@(_paymentOutstanding > 0 ? Color.Warning : Color.Success)"><b>@($"{_paymentOutstanding:N0} đ")</b></MudText>
                        </MudItem>
                    </MudGrid>
                    @if (_overduePaymentCount > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            Có @_overduePaymentCount khoản quá hạn/chưa thu đủ.
                        </MudAlert>
                    }
                    @if (_payments.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">Chưa có khoản thu nào cho ứng viên này.</MudAlert>
                    }
                    else
                    {
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <div class="table-scroll-x">
                                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                                    <thead>
                                        <tr>
                                            <th>Mã</th>
                                            <th>Loại</th>
                                            <th style="text-align:right">Số tiền</th>
                                            <th>Trạng thái</th>
                                            <th>Hạn thu</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var payment in _payments)
                                        {
                                            <tr>
                                                <td>@payment.Code</td>
                                                <td>@Labels.Vi(payment.Type)</td>
                                                <td style="text-align:right">@($"{payment.Amount:N0} đ")</td>
                                                <td><MudChip T="string" Size="Size.Small" Color="Labels.ColorOf(payment.Status)">@Labels.Vi(payment.Status)</MudChip></td>
                                                <td>@(payment.DueDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </div>
                        </MudHidden>

                        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
                            @foreach (var payment in _payments)
                            {
                                <MudPaper Class="mobile-card pa-3" Elevation="0">
                                    <div class="d-flex justify-space-between align-center" style="gap:8px">
                                        <div style="min-width:0">
                                            <MudText Typo="Typo.subtitle2" Style="font-weight:600">@Labels.Vi(payment.Type)</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@payment.Code</MudText>
                                        </div>
                                        <MudChip T="string" Size="Size.Small" Color="Labels.ColorOf(payment.Status)">@Labels.Vi(payment.Status)</MudChip>
                                    </div>
                                    <div class="d-flex justify-space-between align-center mt-1" style="gap:8px">
                                        <MudText Typo="Typo.body2"><b>@($"{payment.Amount:N0} đ")</b></MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Hạn: @(payment.DueDate?.ToString("dd/MM/yyyy") ?? "—")</MudText>
                                    </div>
                                </MudPaper>
                            }
                        </MudHidden>
                    }
                </MudPaper>
            }

            @if (_canReadLoan)
            {
                <MudPaper Class="pa-4 mt-4" Elevation="1">
                    <div class="d-flex justify-space-between align-center mb-3">
                        <div class="d-flex align-center" style="gap:8px">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" />
                            <MudText Typo="Typo.subtitle1"><b>Hỗ trợ vay vốn</b></MudText>
                        </div>
                        @if (_hasLoan)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Labels.ColorOf(_loanStatus)" Icon="@Labels.IconOf(_loanStatus)">@Labels.Vi(_loanStatus)</MudChip>
                        }
                    </div>
                    @if (_hasLoan)
                    {
                        <MudGrid>
                            @Field("Số tiền vay", _loanAmount is null ? null : $"{_loanAmount:N0} đ")
                            @Field("Thời hạn", _loanTermMonths is null ? null : $"{_loanTermMonths} tháng")
                            @Field("Ngân hàng", _loanBankName)
                            @Field("Lãi suất", _loanInterestRate is null ? null : $"{_loanInterestRate}%/năm")
                            @Field("Ngày giải ngân", _loanDisbursedDate?.ToString("dd/MM/yyyy"))
                        </MudGrid>
                        @if (!string.IsNullOrWhiteSpace(_loanNote))
                        {
                            <MudText Typo="Typo.body2" Class="mt-2"><b>Ghi chú:</b> @_loanNote</MudText>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">Ứng viên chưa có khoản vay. Bấm thêm khoản vay khi cần hỗ trợ vay vốn.</MudAlert>
                    }
                    @if (_canUpdateLoan)
                    {
                        <MudButton Class="mt-3 entity-action-button" Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                                   StartIcon="@(_hasLoan ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" OnClick="OpenLoanEdit">
                            @(_hasLoan ? "Cập nhật khoản vay" : "Thêm khoản vay")
                        </MudButton>
                    }
                    @if (_hasLoan && _canDeleteLoan)
                    {
                        <MudButton Class="mt-2 entity-action-button" Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteCandidateLoan" Disabled="_busy">
                            Xóa khoản vay
                        </MudButton>
                    }
                </MudPaper>
            }
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Quy trình 20 bước</b></MudText>
                @if (_cjo is null)
                {
                    <MudAlert Severity="Severity.Info">Ứng viên chưa được gắn vào đơn hàng nào.</MudAlert>
                }
                else
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start" Class="workflow-timeline">
                        @foreach (var step in TimelineSteps)
                        {
                            var state = StateOf(step);
                            <MudTimelineItem Color="@state.Color" Size="Size.Small"
                                             Icon="@(state.Done ? Icons.Material.Filled.Check : state.Current ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.RadioButtonUnchecked)">
                                <MudText Typo="Typo.body2" Style="@(state.Pending ? "color:#94a3b8" : "")">
                                    <b>@(WorkflowSteps.No(step)).</b> @Labels.Vi(step)
                                </MudText>
                                @if (state.Current)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="@(step == WorkflowStep.ReselectJobOrder ? Color.Warning : Color.Primary)" Class="mt-1">Đang xử lý</MudChip>
                                }
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
            </MudPaper>

            @if (_cjo is not null && _cjo.CurrentStep >= WorkflowStep.OverseasSupport)
            {
                @* B19: nhật ký tương tác giai đoạn xứ người — kéo dài nhiều năm (trả nợ, lấy thuế, tái tuyển khi về nước) *@
                <MudPaper Class="pa-4 mt-4" Elevation="1">
                    <div class="d-flex align-center mb-3" style="gap:8px">
                        <MudIcon Icon="@Icons.Material.Filled.Public" Color="Color.Info" />
                        <MudText Typo="Typo.subtitle1"><b>Nhật ký tương tác giai đoạn xứ người (@_overseasLogs.Count)</b></MudText>
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-3">
                        Ghi lại các lần liên hệ/hỗ trợ lao động: trả nợ vay, hỗ trợ lấy lại thuế, tái tuyển việc làm trong nước khi về... Nhật ký tiếp tục ghi được cả sau khi hoàn thành quy trình.
                    </MudText>
                    @if (_canLogOverseas)
                    {
                        <MudTextField @bind-Value="_overseasLogText" Label="Nội dung tương tác/hỗ trợ" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2" />
                        <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.NoteAdd"
                                   OnClick="AddOverseasLog" Disabled="@(_busy || string.IsNullOrWhiteSpace(_overseasLogText))" Class="mb-3">
                            Thêm ghi chú
                        </MudButton>
                    }
                    @if (_overseasLogs.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">Chưa có ghi chú tương tác nào.</MudAlert>
                    }
                    else
                    {
                        @foreach (var log in _overseasLogs)
                        {
                            <div class="d-flex py-2" style="gap:10px; border-bottom:1px solid var(--mud-palette-lines-default)">
                                <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Small" Class="mt-1 mud-text-secondary" />
                                <div style="min-width:0">
                                    <MudText Typo="Typo.body2">@log.Notes</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                </div>
                            </div>
                        }
                    }
                </MudPaper>
            }

            <MudPaper Class="pa-4 mt-4" Elevation="1">
                <div class="d-flex justify-space-between align-center mb-3">
                    <MudText Typo="Typo.subtitle1"><b>Hồ sơ ứng viên (@_documents.Count)</b></MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">MinIO</MudChip>
                </div>

                @if (_canUpdateCandidate)
                {
                    <MudGrid Class="mb-3">
                        <MudItem xs="12" sm="4">
                            <MudSelect T="DocumentType" @bind-Value="_uploadDocType" Label="Loại hồ sơ" Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (var type in Enum.GetValues<DocumentType>())
                                {
                                    <MudSelectItem Value="@type">@Labels.Vi(type)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="5">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">File hồ sơ</MudText>
                            <InputFile OnChange="OnDocumentSelected" />
                            @if (_selectedDocumentFile is not null)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @_selectedDocumentFile.Name (@FormatFileSize(_selectedDocumentFile.Size))
                                </MudText>
                            }
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudTextField @bind-Value="_documentNotes" Label="Ghi chú" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile"
                                       Disabled="_uploading || _selectedDocumentFile is null" OnClick="UploadDocument">
                                Upload hồ sơ
                            </MudButton>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2">
                                Hỗ trợ PDF, ảnh, Word, Excel. Tối đa @FormatFileSize(DocumentStorage.MaxUploadBytes).
                            </MudText>
                        </MudItem>
                    </MudGrid>
                }

                @if (_documents.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">Chưa có hồ sơ nào được upload.</MudAlert>
                }
                else
                {
                    <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <div class="table-scroll-x">
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>Loại</th>
                                <th>File hiện hành</th>
                                <th>Phiên bản</th>
                                <th>Dung lượng</th>
                                <th>Upload lúc</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var document in _documents)
                            {
                                <tr>
                                    <td>@Labels.Vi(document.DocType)</td>
                                    <td>
                                        <div>@document.FileName</div>
                                        @if (!string.IsNullOrWhiteSpace(document.Notes))
                                        {
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@document.Notes</MudText>
                                        }
                                    </td>
                                    <td>v@document.VersionNumber</td>
                                    <td>@FormatFileSize(document.FileSize)</td>
                                    <td>@document.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td style="text-align:right; white-space:nowrap">
                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Download"
                                                   OnClick="@(() => DownloadDocument(document.VersionId))">
                                            Tải
                                        </MudButton>
                                        @if (_versionsByDoc.TryGetValue(document.DocumentId, out var vers) && vers.Count > 1)
                                        {
                                            <MudButton Size="Size.Small" Variant="Variant.Text"
                                                       StartIcon="@Icons.Material.Filled.History"
                                                       OnClick="@(() => ToggleHistory(document.DocumentId))">
                                                Lịch sử (@vers.Count)
                                            </MudButton>
                                        }
                                    </td>
                                </tr>
                                @if (_expandedDocId == document.DocumentId && _versionsByDoc.TryGetValue(document.DocumentId, out var history))
                                {
                                    <tr>
                                        <td colspan="6" style="background-color: var(--mud-palette-background-grey)">
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1"><b>Các phiên bản</b></MudText>
                                            @foreach (var v in history)
                                            {
                                                <div class="d-flex align-center py-1" style="gap:8px">
                                                    <MudChip T="string" Size="Size.Small" Color="@(v.IsCurrent ? Color.Success : Color.Default)">v@v.VersionNumber</MudChip>
                                                    <span class="flex-grow-1">@v.FileName <span class="mud-text-secondary">(@FormatFileSize(v.FileSize) — @v.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</span></span>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" OnClick="@(() => DownloadDocument(v.VersionId))" />
                                                    @if (_canUpdateCandidate && !v.IsCurrent)
                                                    {
                                                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                                                   StartIcon="@Icons.Material.Filled.RestartAlt"
                                                                   OnClick="@(() => RestoreVersion(document.DocumentId, v.VersionId))">
                                                            Đặt hiện hành
                                                        </MudButton>
                                                    }
                                                    else if (v.IsCurrent)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Success">Hiện hành</MudText>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </MudSimpleTable>
                    </div>
                    </MudHidden>

                    <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
                        @foreach (var document in _documents)
                        {
                            <MudPaper Class="mobile-card pa-3" Elevation="0">
                                <div class="d-flex justify-space-between align-center" style="gap:8px">
                                    <div style="min-width:0">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600">@Labels.Vi(document.DocType)</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="word-break:break-all">@document.FileName</MudText>
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">v@document.VersionNumber</MudChip>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(document.Notes))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@document.Notes</MudText>
                                }
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
                                    @FormatFileSize(document.FileSize) • @document.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </MudText>
                                <div class="d-flex flex-wrap mt-1" style="gap:4px">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Download"
                                               OnClick="@(() => DownloadDocument(document.VersionId))">
                                        Tải
                                    </MudButton>
                                    @if (_versionsByDoc.TryGetValue(document.DocumentId, out var mvers) && mvers.Count > 1)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                                   StartIcon="@Icons.Material.Filled.History"
                                                   OnClick="@(() => ToggleHistory(document.DocumentId))">
                                            Lịch sử (@mvers.Count)
                                        </MudButton>
                                    }
                                </div>
                                @if (_expandedDocId == document.DocumentId && _versionsByDoc.TryGetValue(document.DocumentId, out var mhistory))
                                {
                                    <MudDivider Class="my-2" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1"><b>Các phiên bản</b></MudText>
                                    @foreach (var v in mhistory)
                                    {
                                        <div class="d-flex align-center py-1" style="gap:8px">
                                            <MudChip T="string" Size="Size.Small" Color="@(v.IsCurrent ? Color.Success : Color.Default)">v@v.VersionNumber</MudChip>
                                            <span class="flex-grow-1" style="min-width:0;word-break:break-all">@v.FileName <span class="mud-text-secondary">(@FormatFileSize(v.FileSize))</span></span>
                                            <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" OnClick="@(() => DownloadDocument(v.VersionId))" />
                                            @if (_canUpdateCandidate && !v.IsCurrent)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => RestoreVersion(document.DocumentId, v.VersionId))" />
                                            }
                                        </div>
                                    }
                                }
                            </MudPaper>
                        }
                    </MudHidden>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Candidate? _candidate;
    private CandidateJobOrder? _cjo;
    private string? _country;
    private Guid? _consultantId;
    private string _consultantName = "—";
    private Guid? _collaboratorId;
    private string _collaboratorName = "—";
    private bool _busy;
    private bool _accessDenied;
    private bool _canUpdateCandidate;
    private bool _canEditCandidateProfile;
    private bool _canDeleteCandidate;
    private bool _canReadPayments;
    private bool _canReadLoan;
    private bool _canUpdateLoan;
    private bool _canDeleteLoan;
    private bool _canAssignJobOrder;
    private bool _canAdvanceWorkflow;
    private string _workflowOwnerLabel = "";

    // Tình huống theo bước (dấu "/" trong tên bước = lựa chọn theo hồ sơ)
    private string? _examMode;            // B8: Thi tuyển | Phỏng vấn | Xét duyệt hồ sơ
    private string _failNotes = "";       // B8: lý do rớt/từ chối
    private bool _learnLanguage;          // B10: học tiếng
    private bool _learnOrientation;       // B10: học định hướng
    private bool _learnVocational;        // B10: học nghề
    private bool _skipTraining;           // B10: bỏ qua ("nếu cần")
    private string? _paymentMode;         // B15: Thanh toán hoàn tất | Cam kết trả nợ
    private string? _lastFailNote;        // B7.5: lý do rớt gần nhất để hiển thị
    private List<JobOrder> _reassignJobOrders = new(); // B7.5: đơn hàng mới (khác đơn cũ)
    private Guid? _reassignJobOrderId;
    private string _reassignNotes = "";
    private List<WorkflowStepRecord> _overseasLogs = new(); // B19: nhật ký tương tác
    private string _overseasLogText = "";
    private bool _canLogOverseas;

    private bool _hasLoan;
    private LoanStatus _loanStatus = LoanStatus.Borrowing;
    private decimal? _loanAmount;
    private int? _loanTermMonths;
    private string? _loanBankName;
    private decimal? _loanInterestRate;
    private DateOnly? _loanDisbursedDate;
    private string? _loanNote;

    private List<JobOrder> _jobOrders = new();
    private List<CandidatePaymentRow> _payments = new();
    private List<CandidateDocumentRow> _documents = new();
    private Guid? _selectedJobOrderId;
    private string _assignNotes = "";
    private decimal _paymentTotal;
    private decimal _paymentPaid;
    private decimal _paymentOutstanding;
    private int _overduePaymentCount;
    private DocumentType _uploadDocType = DocumentType.Cccd;
    private IBrowserFile? _selectedDocumentFile;
    private string _documentNotes = "";
    private bool _uploading;

    private record CandidatePaymentRow(Guid Id, string Code, PaymentType Type, decimal Amount, PaymentStatus Status, DateOnly? DueDate, DateOnly? PaidDate);
    private record CandidateDocumentRow(
        Guid DocumentId,
        Guid VersionId,
        DocumentType DocType,
        string FileName,
        long FileSize,
        string? MimeType,
        int VersionNumber,
        DateTimeOffset UploadedAt,
        string? Notes);
    private record DocumentVersionRow(Guid VersionId, int VersionNumber, string FileName, long FileSize, DateTimeOffset UploadedAt, bool IsCurrent);

    private Dictionary<Guid, List<DocumentVersionRow>> _versionsByDoc = new();
    private Guid? _expandedDocId;

    private bool HasEmergencyInfo => !string.IsNullOrWhiteSpace(_candidate?.EmergencyContactName)
        || !string.IsNullOrWhiteSpace(_candidate?.EmergencyContactPhone);
    private bool HasBankInfo => !string.IsNullOrWhiteSpace(_candidate?.BankAccountNumber)
        || !string.IsNullOrWhiteSpace(_candidate?.BankName);
    private bool HasGuardianInfo => !string.IsNullOrWhiteSpace(_candidate?.GuardianName)
        || !string.IsNullOrWhiteSpace(_candidate?.GuardianPhone);
    private bool CanShowCandidateDebt => _canReadPayments && _cjo?.CurrentStep >= WorkflowStep.Deposit;
    private bool _hasOpenLoan; // còn khoản vay chưa tất toán → chặn B20

    /// <summary>20 bước chính; chèn bước phụ 7.5 ngay trước B8 khi hồ sơ đang ở đó.</summary>
    private IEnumerable<WorkflowStep> TimelineSteps
    {
        get
        {
            foreach (var s in WorkflowSteps.Main)
            {
                if (s == WorkflowStep.EntranceExam && _cjo?.CurrentStep == WorkflowStep.ReselectJobOrder)
                    yield return WorkflowStep.ReselectJobOrder;
                yield return s;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _canUpdateCandidate = await HasPermission("candidates:update");
        _canEditCandidateProfile = _canUpdateCandidate && BusinessRoleAccess.CanEditCandidateProfile(authState.User);
        _canDeleteCandidate = await HasPermission("candidates:delete") && BusinessRoleAccess.CanDeleteCandidate(authState.User);
        _canReadPayments = await HasPermission("payments:read");
        _canReadLoan = await HasPermission("loans:read");
        _canUpdateLoan = await HasPermission("loans:update") && BusinessRoleAccess.CanEditLoan(authState.User);
        _canDeleteLoan = await HasPermission("loans:delete") && BusinessRoleAccess.CanDeleteLoan(authState.User);
        _canAssignJobOrder = WorkflowStepAccess.CanAssignJobOrder(authState.User);
        await Load();
    }

    private async Task Load()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _candidate = await db.Candidates.FirstOrDefaultAsync(c => c.Id == Id);
        if (_candidate is null) return;

        // Đại lý chỉ được xem ứng viên do mình giới thiệu (spec §2.8).
        var scope = await AgentScope.GetAsync();
        if ((scope.IsAgentOnly && _candidate.AgentId != scope.AgentId)
            || (scope.IsCollaboratorOnly && _candidate.CollaboratorId != scope.CollaboratorId))
        {
            _accessDenied = true;
            _candidate = null;
            return;
        }
        // Người phụ trách: Tư vấn viên (tài khoản role consultant) + Cộng tác viên (nguồn giới thiệu).
        _consultantId = _candidate.ConsultantId;
        if (_consultantId is not null)
        {
            var c = await db.Users.Where(u => u.Id == _consultantId.Value)
                .Select(u => new { u.FullName, u.Email }).FirstOrDefaultAsync();
            _consultantName = string.IsNullOrWhiteSpace(c?.FullName) ? (c?.Email ?? "—") : c.FullName;
        }
        _collaboratorId = _candidate.CollaboratorId;
        if (_collaboratorId is not null)
        {
            _collaboratorName = await db.Collaborators.Where(x => x.Id == _collaboratorId.Value)
                .Select(x => x.FullName).FirstOrDefaultAsync() ?? "—";
        }

        if (_canReadLoan)
        {
            var loan = await db.Loans.Where(l => l.CandidateId == Id)
                .OrderByDescending(l => l.CreatedAt).FirstOrDefaultAsync();
            _hasLoan = loan is not null;
            _loanStatus = loan?.Status == LoanStatus.NotBorrowed ? LoanStatus.Borrowing : loan?.Status ?? LoanStatus.Borrowing;
            _loanAmount = loan?.Amount;
            _loanTermMonths = loan?.TermMonths;
            _loanBankName = loan?.BankName;
            _loanInterestRate = loan?.InterestRate;
            _loanDisbursedDate = loan?.DisbursedDate;
            _loanNote = loan?.Note;
            _hasOpenLoan = loan is not null && loan.Status != LoanStatus.Settled;
        }

        _cjo = await db.CandidateJobOrders.Where(j => j.CandidateId == Id)
            .OrderByDescending(j => j.CreatedAt).FirstOrDefaultAsync();
        if (_cjo is not null)
        {
            _country = await db.JobOrders.Where(j => j.Id == _cjo.JobOrderId).Select(j => j.Country).FirstOrDefaultAsync();
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _canAdvanceWorkflow = WorkflowStepAccess.CanAdvance(authState.User, _cjo.CurrentStep);
            _workflowOwnerLabel = WorkflowStepAccess.OwnerLabel(_cjo.CurrentStep);
            _canLogOverseas = _canUpdateCandidate
                || WorkflowStepAccess.CanAdvance(authState.User, WorkflowStep.OverseasSupport);

            if (_cjo.CurrentStep == WorkflowStep.ReselectJobOrder)
            {
                // Bước 7.5: chỉ được chọn đơn hàng MỚI (khác đơn rớt), còn hạn ứng tuyển.
                var todayDeadline = DateOnly.FromDateTime(DateTime.Today);
                _reassignJobOrders = await db.JobOrders
                    .Where(j => j.Id != _cjo.JobOrderId
                                && j.Status != JobOrderStatus.Cancelled
                                && (j.ApplicationDeadline == null || j.ApplicationDeadline >= todayDeadline))
                    .OrderByDescending(j => j.CreatedAt).ToListAsync();
                _lastFailNote = await db.WorkflowStepRecords
                    .Where(r => r.CandidateJobOrderId == _cjo.Id && r.Step == WorkflowStep.EntranceExam && r.Status == WorkflowStepStatus.Failed)
                    .OrderByDescending(r => r.CreatedAt)
                    .Select(r => r.Notes)
                    .FirstOrDefaultAsync();
            }

            if (_cjo.CurrentStep >= WorkflowStep.OverseasSupport)
            {
                // Nhật ký B19 = các record InProgress của bước OverseasSupport (mỗi ghi chú 1 record).
                _overseasLogs = await db.WorkflowStepRecords
                    .Where(r => r.CandidateJobOrderId == _cjo.Id && r.Step == WorkflowStep.OverseasSupport && r.Status == WorkflowStepStatus.InProgress)
                    .OrderByDescending(r => r.CreatedAt)
                    .ToListAsync();
            }
        }
        else
        {
            _canAdvanceWorkflow = false;
            _workflowOwnerLabel = "";
            // Job hết hạn ứng tuyển không nhận thêm ứng viên (góp ý Vietgroup).
            var todayForDeadline = DateOnly.FromDateTime(DateTime.Today);
            _jobOrders = await db.JobOrders
                .Where(j => j.Status != JobOrderStatus.Cancelled
                            && (j.ApplicationDeadline == null || j.ApplicationDeadline >= todayForDeadline))
                .OrderByDescending(j => j.CreatedAt).ToListAsync();
        }

        if (CanShowCandidateDebt)
        {
            var payments = await db.Payments
                .Where(p => p.CandidateId == Id)
                .OrderByDescending(p => p.CreatedAt)
                .ToListAsync();

            _payments = payments.Select(p => new CandidatePaymentRow(
                p.Id,
                p.Code,
                p.PaymentType,
                p.Amount,
                p.Status,
                p.DueDate,
                p.PaidDate)).ToList();

            _paymentTotal = payments.Where(p => p.Status != PaymentStatus.Refunded).Sum(p => p.Amount);
            _paymentPaid = payments.Where(p => p.Status == PaymentStatus.Paid).Sum(p => p.Amount);
            _paymentOutstanding = Math.Max(0, _paymentTotal - _paymentPaid);
            var today = DateOnly.FromDateTime(DateTime.UtcNow);
            _overduePaymentCount = payments.Count(p =>
                p.Status is PaymentStatus.Pending or PaymentStatus.Partial or PaymentStatus.Overdue
                && p.DueDate is not null
                && p.DueDate.Value < today);
        }

        var documents = await db.CandidateDocuments
            .Where(d => d.CandidateId == Id)
            .OrderBy(d => d.DocType)
            .ToListAsync();

        if (documents.Count == 0)
        {
            _documents = new();
            return;
        }

        var documentIds = documents.Select(d => d.Id).ToList();
        var versions = await db.DocumentVersions
            .Where(v => documentIds.Contains(v.DocumentId))
            .OrderByDescending(v => v.VersionNumber)
            .ToListAsync();

        _documents = documents
            .Select(d =>
            {
                var current = d.CurrentVersionId is null
                    ? versions.FirstOrDefault(v => v.DocumentId == d.Id)
                    : versions.FirstOrDefault(v => v.Id == d.CurrentVersionId.Value)
                        ?? versions.FirstOrDefault(v => v.DocumentId == d.Id);

                return current is null
                    ? null
                    : new CandidateDocumentRow(
                        d.Id,
                        current.Id,
                        d.DocType,
                        current.FileName,
                        current.FileSize,
                        current.MimeType,
                        current.VersionNumber,
                        current.CreatedAt,
                        current.Notes);
            })
            .Where(row => row is not null)
            .Cast<CandidateDocumentRow>()
            .ToList();

        _versionsByDoc = documents.ToDictionary(
            d => d.Id,
            d => versions.Where(v => v.DocumentId == d.Id)
                .OrderByDescending(v => v.VersionNumber)
                .Select(v => new DocumentVersionRow(v.Id, v.VersionNumber, v.FileName, v.FileSize, v.CreatedAt,
                    d.CurrentVersionId == v.Id))
                .ToList());
    }

