@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="pt-2">
            <MudTabPanel Text="Thông tin cá nhân">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.FullName" Label="Họ tên *" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.Phone" Label="Số điện thoại" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Gender?" @bind-Value="_m.Gender" Label="Giới tính" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var g in Enum.GetValues<Gender>())
                            {
                                <MudSelectItem T="Gender?" Value="@g">@Labels.Vi(g)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_m.Dob" Label="Ngày sinh" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       DateFormat="dd/MM/yyyy" MaxDate="DateTime.Today" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="MaritalStatus?" @bind-Value="_m.MaritalStatus" Label="Tình trạng hôn nhân" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var s in Enum.GetValues<MaritalStatus>())
                            {
                                <MudSelectItem T="MaritalStatus?" Value="@s">@Labels.Vi(s)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudAutocomplete T="string" @bind-Value="_m.Province" Label="Tỉnh/Thành phố"
                                         SearchFunc="SearchProvince" CoerceValue="true" ResetValueOnEmptyText="false"
                                         Clearable="true" MaxItems="40" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_m.Address" Label="Địa chỉ" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Giấy tờ">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.CccdNumber" Label="Số CCCD" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_m.CccdIssueDate" Label="Ngày cấp CCCD" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       DateFormat="dd/MM/yyyy" MaxDate="DateTime.Today" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.CccdIssuePlace" Label="Nơi cấp CCCD" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.PassportNumber" Label="Số hộ chiếu" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_m.PassportExpiry" Label="Hộ chiếu hết hạn" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       DateFormat="dd/MM/yyyy" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Liên hệ khẩn cấp">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.EmergencyContactName" Label="Người liên hệ" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.EmergencyContactPhone" Label="SĐT liên hệ" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.EmergencyContactRelation" Label="Quan hệ" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Cha/Mẹ/Người bảo hộ">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.GuardianName" Label="Họ tên" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.GuardianRelation" Label="Quan hệ (cha/mẹ/người bảo hộ…)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.GuardianPhone" Label="Số điện thoại" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.GuardianCccd" Label="Số CCCD" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.GuardianOccupation" Label="Nghề nghiệp" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_m.GuardianAddress" Label="Địa chỉ" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Ngân hàng">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.BankAccountNumber" Label="Số tài khoản" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.BankName" Label="Ngân hàng" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_m.BankAccountName" Label="Chủ tài khoản" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Tư vấn & Nguồn">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Guid?" @bind-Value="_m.ConsultantId" Label="Tư vấn viên phụ trách" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                                   Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.SupportAgent">
                            @foreach (var u in _consultants)
                            {
                                <MudSelectItem T="Guid?" Value="@u.Id">@u.FullName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Tư vấn viên theo sát ứng viên trong suốt quy trình (1 tư vấn viên phụ trách nhiều ứng viên).</MudText>
                    </MudItem>
                    <MudItem xs="12"><MudDivider Class="my-1" /></MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Guid?" @bind-Value="_m.AgentId" Label="Đại lý (nguồn giới thiệu)" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var a in _agents)
                            {
                                <MudSelectItem T="Guid?" Value="@a.Id">@a.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Guid?" @bind-Value="_m.CollaboratorId" Label="Cộng tác viên (CTV) giới thiệu" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                                   Disabled="@(_m.AgentId is null)">
                            @foreach (var c in _collaborators.Where(c => c.AgentId == _m.AgentId))
                            {
                                <MudSelectItem T="Guid?" Value="@c.Id">@c.FullName (@c.Code)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">CTV giới thiệu (nếu có): chọn đại lý trước, sau đó chọn CTV trực thuộc. Chỉ điền khi ứng viên do CTV giới thiệu.</MudText>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            @* Thông tin nhạy cảm — chỉ super_admin được xem/sửa *@
            <AuthorizeView Roles="super_admin">
                <Authorized>
                    <MudTabPanel Text="Hồ sơ (Super admin)" Icon="@Icons.Material.Filled.Lock">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_m.Email" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_m.Occupation" Label="Nghề nghiệp hiện tại" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_m.EducationLevel" Label="Trình độ học vấn" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_m.WorkExperience" Label="Kinh nghiệm làm việc" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_m.Languages" Label="Ngoại ngữ" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                </Authorized>
            </AuthorizeView>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="_saving">Lưu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Null = tạo mới; có giá trị = sửa ứng viên hiện có.</summary>
    [Parameter] public Guid? CandidateId { get; set; }

    private readonly FormModel _m = new();
    private bool _saving;
    private bool _canEditSensitiveProfile;
    private bool IsEdit => CandidateId is not null;

    private List<Agent> _agents = new();
    private List<Collaborator> _collaborators = new();
    private record UserOption(Guid Id, string FullName);
    private List<UserOption> _consultants = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _canEditSensitiveProfile = authState.User.IsInRole(Polymind.Infrastructure.Persistence.Constants.RoleNames.SuperAdmin);

        await using var db = await DbFactory.CreateDbContextAsync();
        _agents = await db.Agents.OrderBy(a => a.Name).ToListAsync();
        _collaborators = await db.Collaborators.OrderBy(c => c.FullName).ToListAsync();

        var consultantRoleId = await db.Roles
            .Where(r => r.Name == Polymind.Infrastructure.Persistence.Constants.RoleNames.Consultant)
            .Select(r => r.Id).FirstOrDefaultAsync();
        _consultants = await db.Users
            .Where(u => u.IsActive && db.UserRoles.Any(ur => ur.UserId == u.Id && ur.RoleId == consultantRoleId))
            .OrderBy(u => u.FullName)
            .Select(u => new UserOption(u.Id, u.FullName)).ToListAsync();

        if (CandidateId is null) return;
        var c = await db.Candidates.FirstOrDefaultAsync(x => x.Id == CandidateId);
        if (c is not null) _m.LoadFrom(c);
    }

    private Task<IEnumerable<string>> SearchProvince(string value, CancellationToken token)
        => Task.FromResult(VietnamProvinces.Search(value));

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_m.FullName))
        {
            Snackbar.Add("Vui lòng nhập họ tên.", Severity.Warning);
            return;
        }

        var permission = IsEdit ? "candidates:update" : "candidates:create";
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authorization = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        if (!authorization.Succeeded || (IsEdit && !BusinessRoleAccess.CanEditCandidateProfile(authState.User)))
        {
            Snackbar.Add("Bạn không có quyền thực hiện thao tác này.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            if (IsEdit)
            {
                var c = await db.Candidates.FirstOrDefaultAsync(x => x.Id == CandidateId);
                if (c is null)
                {
                    Snackbar.Add("Không tìm thấy ứng viên.", Severity.Error);
                    return;
                }
                var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
                var oldValue = Snapshot(c);
                _m.ApplyTo(c, _canEditSensitiveProfile);
                c.UpdatedAt = DateTimeOffset.UtcNow;
                db.AddAudit(actorId, "update", "candidates", c.Id, oldValue, Snapshot(c));
            }
            else
            {
                var actorId = await AuthStateProvider.GetRequiredUserIdAsync(db);
                var c = new Candidate
                {
                    Code = $"UV-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1000, 9999)}",
                    CreatedBy = actorId,
                };
                _m.ApplyTo(c, _canEditSensitiveProfile);
                db.Candidates.Add(c);
                db.AddAudit(actorId, "create", "candidates", c.Id, null, Snapshot(c));
            }
            await db.SaveChangesAsync();
        }
        finally
        {
            _saving = false;
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task<bool> HasPermission(string permission)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var result = await AuthorizationService.AuthorizeAsync(authState.User, null, permission);
        return result.Succeeded;
    }

    private static object Snapshot(Candidate c) => new
    {
        c.Code,
        c.FullName,
        c.Phone,
        c.Gender,
        c.Dob,
        c.Province,
        c.Address,
        c.MaritalStatus,
        c.CccdNumber,
        c.CccdIssueDate,
        c.CccdIssuePlace,
        c.PassportNumber,
        c.PassportExpiry,
        c.EmergencyContactName,
        c.EmergencyContactPhone,
        c.EmergencyContactRelation,
        c.GuardianName,
        c.GuardianRelation,
        c.GuardianPhone,
        c.GuardianCccd,
        c.GuardianAddress,
        c.GuardianOccupation,
        c.BankAccountNumber,
        c.BankName,
        c.BankAccountName,
        c.Email,
        c.Occupation,
        c.EducationLevel,
        c.WorkExperience,
        c.Languages,
        c.AgentId,
        c.CollaboratorId,
        c.ConsultantId,
        c.CreatedBy,
    };

    /// <summary>Model tách riêng để dùng DateTime? cho MudDatePicker rồi map sang DateOnly?.</summary>
    private sealed class FormModel
    {
        public string FullName { get; set; } = "";
        public string? Phone { get; set; }
        public Gender? Gender { get; set; }
        public DateTime? Dob { get; set; }
        public string? Province { get; set; }
        public string? Address { get; set; }
        public MaritalStatus? MaritalStatus { get; set; }
        public string? CccdNumber { get; set; }
        public DateTime? CccdIssueDate { get; set; }
        public string? CccdIssuePlace { get; set; }
        public string? PassportNumber { get; set; }
        public DateTime? PassportExpiry { get; set; }
        public string? EmergencyContactName { get; set; }
        public string? EmergencyContactPhone { get; set; }
        public string? EmergencyContactRelation { get; set; }
        public string? GuardianName { get; set; }
        public string? GuardianRelation { get; set; }
        public string? GuardianPhone { get; set; }
        public string? GuardianCccd { get; set; }
        public string? GuardianAddress { get; set; }
        public string? GuardianOccupation { get; set; }
        public string? BankAccountNumber { get; set; }
        public string? BankName { get; set; }
        public string? BankAccountName { get; set; }
        public string? Email { get; set; }
        public string? Occupation { get; set; }
        public string? EducationLevel { get; set; }
        public string? WorkExperience { get; set; }
        public string? Languages { get; set; }
        public Guid? AgentId { get; set; }
        public Guid? CollaboratorId { get; set; }
        public Guid? ConsultantId { get; set; }

        public void LoadFrom(Candidate c)
        {
            FullName = c.FullName;
            Phone = c.Phone;
            Gender = c.Gender;
            Dob = c.Dob?.ToDateTime(TimeOnly.MinValue);
            Province = c.Province;
            Address = c.Address;
            MaritalStatus = c.MaritalStatus;
            CccdNumber = c.CccdNumber;
            CccdIssueDate = c.CccdIssueDate?.ToDateTime(TimeOnly.MinValue);
            CccdIssuePlace = c.CccdIssuePlace;
            PassportNumber = c.PassportNumber;
            PassportExpiry = c.PassportExpiry?.ToDateTime(TimeOnly.MinValue);
            EmergencyContactName = c.EmergencyContactName;
            EmergencyContactPhone = c.EmergencyContactPhone;
            EmergencyContactRelation = c.EmergencyContactRelation;
            GuardianName = c.GuardianName;
            GuardianRelation = c.GuardianRelation;
            GuardianPhone = c.GuardianPhone;
            GuardianCccd = c.GuardianCccd;
            GuardianAddress = c.GuardianAddress;
            GuardianOccupation = c.GuardianOccupation;
            BankAccountNumber = c.BankAccountNumber;
            BankName = c.BankName;
            BankAccountName = c.BankAccountName;
            Email = c.Email;
            Occupation = c.Occupation;
            EducationLevel = c.EducationLevel;
            WorkExperience = c.WorkExperience;
            Languages = c.Languages;
            AgentId = c.AgentId;
            CollaboratorId = c.CollaboratorId;
            ConsultantId = c.ConsultantId;
        }

        public void ApplyTo(Candidate c, bool includeSensitiveProfile)
        {
            c.FullName = FullName.Trim();
            c.Phone = Phone;
            c.Gender = Gender;
            c.Dob = Dob is null ? null : DateOnly.FromDateTime(Dob.Value);
            c.Province = Province;
            c.Address = Address;
            c.MaritalStatus = MaritalStatus;
            c.CccdNumber = CccdNumber;
            c.CccdIssueDate = CccdIssueDate is null ? null : DateOnly.FromDateTime(CccdIssueDate.Value);
            c.CccdIssuePlace = CccdIssuePlace;
            c.PassportNumber = PassportNumber;
            c.PassportExpiry = PassportExpiry is null ? null : DateOnly.FromDateTime(PassportExpiry.Value);
            c.EmergencyContactName = EmergencyContactName;
            c.EmergencyContactPhone = EmergencyContactPhone;
            c.EmergencyContactRelation = EmergencyContactRelation;
            c.GuardianName = GuardianName;
            c.GuardianRelation = GuardianRelation;
            c.GuardianPhone = GuardianPhone;
            c.GuardianCccd = GuardianCccd;
            c.GuardianAddress = GuardianAddress;
            c.GuardianOccupation = GuardianOccupation;
            c.BankAccountNumber = BankAccountNumber;
            c.BankName = BankName;
            c.BankAccountName = BankAccountName;
            c.AgentId = AgentId;
            c.CollaboratorId = AgentId is null ? null : CollaboratorId;
            c.ConsultantId = ConsultantId;

            if (!includeSensitiveProfile) return;

            c.Email = Email;
            c.Occupation = Occupation;
            c.EducationLevel = EducationLevel;
            c.WorkExperience = WorkExperience;
            c.Languages = Languages;
        }
    }
}
