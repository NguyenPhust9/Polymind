# Copy to .env.production, change every secret, then run (chọn 1 profile reverse proxy):
#   Caddy + DuckDNS (khuyến nghị): docker compose --env-file .env.production -f docker-compose.production.yml --profile caddy up -d --build
#   Nginx cert thủ công (fallback): docker compose --env-file .env.production -f docker-compose.production.yml --profile nginx up -d --build

# === Super admin THẬT cho production (BẮT BUỘC — Production không tạo tài khoản mẫu Admin@123) ===
# Nếu để trống, app sẽ KHÔNG tạo tài khoản nào và bạn không đăng nhập được.
# Mật khẩu phải mạnh (>= 8 ký tự, có hoa/thường/số/ký tự đặc biệt theo Identity policy).
SUPERADMIN_EMAIL=admin@polymindolms.vn
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SUPERADMIN_FULLNAME=Super Admin

# === Tên miền + email cho HTTPS (profile caddy) ===
# DOMAIN là tên miền DuckDNS, bản ghi A phải trỏ về public IP công ty + đã port-forward 80/443.
DOMAIN=polymindolms.duckdns.org
ACME_EMAIL=admin@polymindolms.vn

# === DuckDNS dynamic IP updater (chỉ khi dùng --profile duckdns) ===
DUCKDNS_SUBDOMAIN=polymindolms
DUCKDNS_TOKEN=CHANGE_ME_DUCKDNS_TOKEN

POSTGRES_DB=polymind
POSTGRES_USER=polymind
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

MINIO_ROOT_USER=polymind-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_BUCKET=polymind-documents

# Khóa ký JWT cho REST API (Phase H). BẮT BUỘC ở production, tối thiểu 32 ký tự ngẫu nhiên.
# Sinh nhanh: openssl rand -base64 48
JWT_KEY=CHANGE_ME_RANDOM_AT_LEAST_32_CHARS_JWT_SIGNING_KEY

# Email notifications. Leave disabled until SMTP credentials are ready.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@polymind.local
SMTP_FROM_NAME=POLYMIND
